@page "/u/{username}"
@model Taskify.Pages.Users.UserProfileModel
@{
    ViewData["Title"] = Model.DisplayedUser != null ? Model.DisplayedUser.Name : "Uživatel nenalezen";
    
    bool isAuth = User.Identity is { IsAuthenticated: true };
    
    if (Model.DisplayedUser != null && !isAuth)
    {
        ViewData["HideNavbar"] = true;
        ViewData["HideFooter"] = true;
    }
}

<link rel="stylesheet" href="~/css/Profile/profile.css" asp-append-version="true" />

@if (Model.DisplayedUser == null)
{
    <div class="container py-5 text-center">
        <i class="bi bi-person-x text-muted display-1"></i>
        <h2 class="fw-bold mt-4">Uživatel nenalezen</h2>
        <p class="text-muted lead">Bohužel jsme nikoho s tímto jménem nenašli, nebo k tomuto profilu nemáte oprávnění.</p>
        <a href="/" class="btn btn-primary rounded-pill px-4 mt-3">Domů</a>
    </div>
}
else
{
    <div class="container py-4 @(isAuth ? "" : "blur-content")">
        <div class="card profile-header-card shadow-sm mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="row align-items-center">
                    <div class="col-md-auto text-center mb-4 mb-md-0">
                        <div class="profile-avatar-container mx-auto">
                            @if (!string.IsNullOrEmpty(Model.DisplayedUser.ProfilePictureUrl)) 
                            {
                                <img src="@Model.DisplayedUser.ProfilePictureUrl" alt="Profilovka" class="profile-avatar">
                            }
                            else
                            {
                                bool isAdmin = Model.UserRole.Contains("Admin");
                                <div class="profile-avatar @(isAdmin ? "bg-danger" : "bg-primary") text-white d-flex align-items-center justify-content-center" style="font-size: 3rem; font-weight: bold;">
                                    @(Model.DisplayedUser.Name?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                            }
                        </div>
                    </div>
                    
                    <div class="col-md text-center text-md-start">
                        <div class="d-flex flex-column flex-md-row align-items-center gap-3 mb-1">
                            <h2 class="fw-bold mb-0">@Model.DisplayedUser.Name</h2>
                            @if (Model.UserRole.Contains("Admin"))
                            {
                                <span class="badge badge-admin rounded-pill px-3 py-2 shadow-sm">
                                    <i class="bi bi-shield-lock-fill me-1"></i> @Model.UserRole
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-custom-info-light text-info border border-info-subtle rounded-pill px-3 py-2">
                                    <i class="bi bi-award-fill me-1"></i> Úroveň @Model.DisplayedUser.Level
                                </span>
                            }
                        </div>
                        <div class="text-muted mb-3 d-flex justify-content-center justify-content-md-start">
                            <span class="small fw-bold">@@@Model.DisplayedUser.UserName</span>
                        </div>
                        
                        <div class="d-flex flex-wrap justify-content-center justify-content-md-start gap-3 text-muted mb-4">
                            @if (!Model.UserRole.Contains("Admin"))
                            {
                                <span><i class="bi bi-person-circle me-1"></i> @Model.UserRole</span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold"><i class="bi bi-shield-fill-check"></i> Autorizovaný administrátor</span>
                            }
                            
                            @if (Model.IsLockedOut && Model.LockoutEnd.HasValue)
                            {
                                <span class="text-danger fw-bold ms-md-2 border-start ps-md-3">
                                    <i class="bi bi-lock-fill me-1"></i>
                                    ZABLOKOVÁN 
                                    @if (Model.LockoutEnd == DateTimeOffset.MaxValue) {
                                        <span>(Trvale)</span>
                                    } else {
                                        var timeLeft = Model.LockoutEnd.Value - DateTimeOffset.UtcNow;
                                        int daysLeft = (int)Math.Ceiling(timeLeft.TotalDays);
                                        <span>do @Model.LockoutEnd.Value.ToString("dd.MM.yyyy HH:mm") (za @daysLeft @(daysLeft == 1 ? "den" : (daysLeft < 5 ? "dny" : "dní")))</span>
                                    }
                                </span>
                            }
                        </div>

                        <div class="d-flex flex-wrap justify-content-center justify-content-md-start gap-2">
                            @if (Model.IsMe && !Model.UserRole.Contains("Admin"))
                            {
                                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-edit-profile">
                                    <i class="bi bi-pencil-square me-2"></i>Nastavení účtu
                                </a>
                                
                                <button type="button" class="btn btn-light rounded-pill px-4 shadow-sm border" onclick="copyProfileLink(this)">
                                    <i class="bi bi-share me-2"></i>Sdílet profil
                                </button>
                            }

                            @if (User.IsInRole("Admin") && !Model.IsMe)
                            {
                                <div class="vr mx-2 d-none d-md-block"></div>
                                @if (Model.IsLockedOut)
                                {
                                    <form method="post" asp-page-handler="ToggleLock" asp-route-userId="@Model.DisplayedUser.Id" class="d-inline">
                                        <button type="submit" class="btn btn-success rounded-pill px-4 shadow-sm">
                                            <i class="bi bi-unlock me-2"></i>Odblokovat uživatele
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-outline-danger rounded-pill px-4 shadow-sm" 
                                            onclick="openLockModal('@Model.DisplayedUser.Id')">
                                        <i class="bi bi-lock me-2"></i>Zablokovat přístup
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-lg-7">
                <div class="card stat-card shadow-sm h-100 no-anim">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4"><i class="bi bi-info-circle text-primary me-2"></i>O mně</h5>
                        <p class="lead fs-6 text-dark" style="white-space: pre-line;">
                            @if(!string.IsNullOrEmpty(Model.DisplayedUser.Bio)) { 
                                @Model.DisplayedUser.Bio 
                            } else { 
                                <span class="text-muted fst-italic">Uživatel o sobě zatím nic nenapsal.</span> 
                            }
                        </p>
                    </div>
                </div>
            </div>

            @* Pravý sloupec - Statistiky *@
            <div class="col-lg-5">
                <div class="card stat-card shadow-sm no-anim">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4"><i class="bi bi-bar-chart-fill text-primary me-2"></i>Statistiky</h5>
                        
                        <div class="mb-4 p-3 bg-custom-warning-light rounded-4 border border-warning-subtle">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-bold text-warning"><i class="bi bi-star-fill me-2"></i>Reputace</span>
                                <span class="h4 fw-bold text-warning mb-0">@Model.DisplayedUser.Reputation</span>
                            </div>
                            <div class="progress xp-progress">
                                <div class="progress-bar bg-custom-warning" style="width: @Math.Min(Model.DisplayedUser.Reputation / 10.0, 100.0)%;"></div>
                            </div>
                        </div>

                        <div class="mb-2 p-3 bg-custom-info-light rounded-4 border border-info-subtle">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-bold text-info"><i class="bi bi-lightning-charge-fill me-2"></i>Zkušenosti (XP)</span>
                                <span class="fw-bold text-info">@Model.DisplayedUser.Points / @Model.NextLevelPoints XP</span>
                            </div>
                            @{
                                double xpPercent = 0;
                                if (Model.NextLevelPoints > 0) xpPercent = ((double)Model.DisplayedUser.Points / Model.NextLevelPoints) * 100;
                            }
                            <div class="progress xp-progress mb-1">
                                <div class="progress-bar bg-custom-info" style="width: @xpPercent%;"></div>
                            </div>
                            <small class="text-muted">Do další úrovně zbývá @(Model.NextLevelPoints - Model.DisplayedUser.Points) XP</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        @if (Model.IsMe)
        {
            <div class="mb-5 pb-5">
                <div class="d-flex justify-content-between align-items-end mb-4 px-2">
                    <div>
                        <h3 class="fw-bold mb-1 text-primary">Úkoly, které řešíte</h3>
                        <p class="text-muted mb-0">Přehled vašich aktivních úkolů, které máte splnit.</p>
                    </div>
                    @if (Model.AssignedTasks.Count > 0)
                    {
                        <a asp-page="/Tasks/Index" asp-route-AssignedToId="@Model.DisplayedUser.Id" asp-route-FromProfile="@Model.DisplayedUser.UserName" class="btn btn-outline-primary rounded-pill px-4 fw-bold">
                            Zobrazit vše <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    }
                </div>

                @if (Model.AssignedTasks.Count == 0)
                {
                    <div class="card border-0 bg-custom-info-light rounded-4 p-5 text-center shadow-sm border border-info-subtle">
                        <i class="bi bi-lightning-charge text-info display-4 mb-3"></i>
                        <h5 class="fw-bold text-info">Momentálně nemáte žádný úkol</h5>
                        <p class="text-muted">Najděte si úkol v okolí a začněte pomáhat!</p>
                        <a asp-page="/Tasks/Index" class="btn btn-primary rounded-pill px-4 mt-2 fw-bold shadow-sm">Hledat úkoly</a>
                    </div>
                }
                else
                {
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                        @foreach (var task in Model.AssignedTasks)
                        {
                            <div class="col">
                                <partial name="_TaskCardPartial" model="task" view-data='@new ViewDataDictionary(ViewData) { { "IsMini", true } }' />
                            </div>
                        }
                    </div>
                }
            </div>
        }
        
        <div class="mb-5">
            <div class="d-flex justify-content-between align-items-end mb-4 px-2">
                <div>
                    <h3 class="fw-bold mb-1">Vytvořené úkoly</h3>
                    <p class="text-muted mb-0">Poslední vytvořené úkoly uživatele @Model.DisplayedUser.Name</p>
                </div>
                @if (Model.CreatedTasks.Count > 0)
                {
                    <a asp-page="/Tasks/Index" asp-route-CreatedById="@Model.DisplayedUser.Id" asp-route-FromProfile="@Model.DisplayedUser.UserName" class="btn btn-outline-primary rounded-pill px-4 fw-bold">
                        Zobrazit vše <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                }
            </div>

            @if (Model.CreatedTasks.Count == 0)
            {
                <div class="card border-0 bg-light rounded-4 p-5 text-center shadow-sm">
                    <i class="bi bi-clipboard-x text-muted display-4 mb-3"></i>
                    <h5 class="fw-bold">Zatím žádné vytvořené úkoly</h5>
                    <p class="text-muted">Uživatel zatím nezaložil žádnou pomoc.</p>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var task in Model.CreatedTasks)
                    {
                        <div class="col">
                            <partial name="_TaskCardPartial" model="task" view-data='@new ViewDataDictionary(ViewData) { { "IsMini", true } }' />
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@if (Model.DisplayedUser != null && !isAuth)
{
    <div class="login-gate-overlay">
        <div class="card border-0 shadow-lg rounded-4 p-5" style="max-width: 500px;">
            <div class="mb-4">
                <i class="bi bi-lock-fill text-primary" style="font-size: 4rem;"></i>
            </div>
            <h3 class="fw-bold mb-3">Chcete vidět profil uživatele @Model.DisplayedUser.Name?</h3>
            <p class="text-muted mb-4">Připojte se k Taskify komunitě, sledujte statistiky ostatních a budujte svou vlastní reputaci!</p>
            <div class="d-grid gap-3">
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary rounded-pill py-3 fw-bold">Přihlásit se</a>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-primary rounded-pill py-3 fw-bold">Vytvořit účet</a>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/Profile/profile.js" asp-append-version="true"></script>
}

<partial name="_LockUserModal" />