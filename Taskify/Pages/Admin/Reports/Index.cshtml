@page
@model Taskify.Pages.Admin.Reports.IndexModel
@{
    ViewData["Title"] = "Správa reportů";
}

<link rel="stylesheet" href="~/css/Admin/Users/Index.css" asp-append-version="true" />

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Admin/AdminDashboard" class="text-decoration-none text-muted">Administrace</a></li>
            <li class="breadcrumb-item active fw-bold text-dark">Reporty</li>
        </ol>
    </nav>

    <h1 class="fw-bold mb-4">Správa hlášení</h1>
    
    <form method="get" id="filterForm" class="mb-5">
        <div class="card shadow-sm border-0 rounded-4 bg-white p-3">
            <div class="row g-3 align-items-center">

                <div class="col-md-6 col-lg-3">
                    <select name="StatusFilter" class="form-select border-0 bg-light rounded-pill shadow-none px-4" onchange="this.form.submit()">
                        <option value="unresolved" selected="@(Model.StatusFilter == "unresolved")">Čekající</option>
                        <option value="resolved" selected="@(Model.StatusFilter == "resolved")">Vyřešené</option>
                        <option value="all" selected="@(Model.StatusFilter == "all")">Vše</option>
                    </select>
                </div>
                
                <div class="col-md-6 col-lg-3">
                    <select name="SelectedReason" class="form-select border-0 bg-light rounded-pill shadow-none px-4" onchange="this.form.submit()">
                        <option value="" selected="@(!Model.SelectedReason.HasValue)">Všechny důvody</option>
                        @foreach (var reason in Enum.GetValues<Taskify.Models.Enums.ReportReason>())
                        {
                            <option value="@reason" selected="@(Model.SelectedReason == reason)">@Model.GetReasonLabel(reason)</option>
                        }
                    </select>
                </div>

                <div class="col-lg-1 ms-auto text-end">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm w-100">
                        <i class="bi bi-filter"></i>
                    </button>
                </div>
                
            </div>
        </div>
    </form>
    
    @if (!Model.Reports.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-check-circle text-success display-1 opacity-25"></i>
            <h4 class="mt-3 text-muted">Žádné reporty neodpovídají filtrům!</h4>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-0">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Datum</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Úkol / ID</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Důvod</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Nahlásil</th>
                            <th class="py-3 text-center text-uppercase small fw-bold text-muted">Stav</th>
                            <th class="py-3 text-end pe-4 text-uppercase small fw-bold text-muted">Akce</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var report in Model.Reports)
                        {
                            <tr class="border-bottom">
                                <td class="ps-4">
                                    <span class="small d-block text-muted">@report.CreatedAt.ToString("dd.MM.yyyy")</span>
                                    <span class="small fw-bold text-dark">@report.CreatedAt.ToString("HH:mm")</span>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@(report.TaskItem?.Title ?? "Neznámý úkol")</div>
                                    <span class="small text-muted">ID: @report.TaskItemId</span>
                                </td>
                                <td>
                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle rounded-pill px-3 py-1">
                                        @Model.GetReasonLabel(report.Reason)
                                    </span>
                                </td>
                                <td>
                                    <a href="/u/@report.Reporter?.UserName" class="text-decoration-none text-dark d-flex align-items-center hover-primary">
                                        <div style="width: 24px; height: 24px; border-radius: 50%; overflow: hidden; background-color: #eee;" class="me-2 shadow-sm hover-lift">
                                            @if (!string.IsNullOrEmpty(report.Reporter?.ProfilePictureUrl)) {
                                                <img src="@report.Reporter.ProfilePictureUrl" class="w-100 h-100 object-fit-cover" />
                                            }
                                        </div>
                                        <div class="d-flex flex-column lh-1">
                                            <span class="small fw-bold text-dark">@report.Reporter?.Name</span>
                                            <small class="text-muted" style="font-size: 0.65rem;">@@@report.Reporter?.UserName</small>
                                        </div>
                                    </a>
                                </td>
                                <td class="text-center">
                                    @if (report.IsResolved)
                                    {
                                        <span class="badge bg-success rounded-circle p-1" title="Vyřešeno">
                                            <i class="bi bi-check-lg text-white"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning rounded-circle p-1" title="Čeká na vyřízení">
                                            <i class="bi bi-clock text-dark"></i>
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-page="./Detail" asp-route-id="@report.Id" class="btn btn-primary btn-sm rounded-pill px-3 fw-bold shadow-sm">
                                        Přejít k řešení
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>