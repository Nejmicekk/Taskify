@page
@model Taskify.Pages.Admin.Reports.IndexModel
@{
    ViewData["Title"] = "Správa reportů";
}

<link rel="stylesheet" href="~/css/Admin/Reports/Index.css" asp-append-version="true" />

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Admin/AdminDashboard" class="text-decoration-none text-muted">Administrace</a></li>
            <li class="breadcrumb-item active fw-bold text-dark">Reporty</li>
        </ol>
    </nav>

    <h1 class="fw-bold mb-4">Správa hlášení</h1>
    
    <form method="get" id="filterForm" class="mb-5">
        <div class="card shadow-sm border-0 rounded-pill bg-white w-auto">
            <div class="card-body p-2">
                <div class="row g-0 align-items-center">
                    
                    <div class="col-lg-4">
                        <div class="dropdown w-100 h-100">
                            <button class="btn btn-lg btn-transparent w-100 text-start border-0 d-flex align-items-center fs-6"
                                    type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-info-circle text-primary me-2"></i>
                                <span class="text-truncate">
                                    @(Model.StatusFilter switch {
                                        "resolved" => "Vyřešené",
                                        "all" => "Vše",
                                        _ => "Čekající"
                                    })
                                </span>
                                <i class="bi bi-chevron-down ms-auto small opacity-50"></i>
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 rounded-4 py-2 mt-2 w-100">
                                <li><a class="dropdown-item px-3 @(Model.StatusFilter == "unresolved" ? "active" : "")" href="?StatusFilter=unresolved&SelectedReason=@Model.SelectedReason">Čekající</a></li>
                                <li><a class="dropdown-item px-3 @(Model.StatusFilter == "resolved" ? "active" : "")" href="?StatusFilter=resolved&SelectedReason=@Model.SelectedReason">Vyřešené</a></li>
                                <li><a class="dropdown-item px-3 @(Model.StatusFilter == "all" ? "active" : "")" href="?StatusFilter=all&SelectedReason=@Model.SelectedReason">Vše</a></li>
                            </ul>
                            <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                        </div>
                    </div>
                    
                    <div class="d-none d-lg-block border-start" style="height: 30px; width: 1px;"></div>

                    <div class="col-lg-5">
                        <div class="dropdown w-100 h-100">
                            <button class="btn btn-lg btn-transparent w-100 text-start border-0 d-flex align-items-center fs-6"
                                    type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-tag-fill text-warning me-2"></i>
                                <span class="text-truncate">
                                    @(Model.SelectedReason.HasValue ? Model.GetReasonLabel(Model.SelectedReason.Value) : "Všechny důvody")
                                </span>
                                <i class="bi bi-chevron-down ms-auto small opacity-50"></i>
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 rounded-4 py-2 mt-2 w-100 overflow-auto" style="max-height: 350px;">
                                <li><a class="dropdown-item px-3 @(!Model.SelectedReason.HasValue ? "active" : "")" href="?StatusFilter=@Model.StatusFilter&SelectedReason=">Všechny důvody</a></li>
                                <li><hr class="dropdown-divider opacity-50"></li>
                                @foreach (var reason in Enum.GetValues<Taskify.Models.Enums.ReportReason>())
                                {
                                    <li>
                                        <a class="dropdown-item px-3 @(Model.SelectedReason == reason ? "active" : "")" 
                                           href="?StatusFilter=@Model.StatusFilter&SelectedReason=@reason">
                                            @Model.GetReasonLabel(reason)
                                        </a>
                                    </li>
                                }
                            </ul>
                            <input type="hidden" name="SelectedReason" value="@Model.SelectedReason" />
                        </div>
                    </div>
                    
                </div>
            </div>
        </div>
    </form>
    
    @if (!Model.Reports.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-check-circle text-success display-1 opacity-25"></i>
            <h4 class="mt-3 text-muted">Žádné reporty neodpovídají filtrům!</h4>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-0">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Datum</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Úkol / ID</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Důvod</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Nahlásil</th>
                            <th class="py-3 text-center text-uppercase small fw-bold text-muted">Stav</th>
                            <th class="py-3 text-end pe-4 text-uppercase small fw-bold text-muted">Akce</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var report in Model.Reports)
                        {
                            <tr class="border-bottom">
                                <td class="ps-4">
                                    <span class="small d-block text-muted">@report.CreatedAt.ToString("dd.MM.yyyy")</span>
                                    <span class="small fw-bold text-dark">@report.CreatedAt.ToString("HH:mm")</span>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@(report.TaskItem?.Title ?? "Neznámý úkol")</div>
                                    <span class="small text-muted">ID: @report.TaskItemId</span>
                                </td>
                                <td>
                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle rounded-pill px-3 py-1">
                                        @Model.GetReasonLabel(report.Reason)
                                    </span>
                                </td>
                                <td>
                                    <a href="/u/@report.Reporter?.UserName" class="text-decoration-none text-dark d-flex align-items-center hover-primary">
                                        <div style="width: 24px; height: 24px; border-radius: 50%; overflow: hidden; background-color: #eee;" class="me-2">
                                            @if (!string.IsNullOrEmpty(report.Reporter?.ProfilePictureUrl)) {
                                                <img src="@report.Reporter.ProfilePictureUrl" class="w-100 h-100 object-fit-cover" />
                                            }
                                        </div>
                                        <span class="small fw-bold">@report.Reporter?.UserName</span>
                                    </a>
                                </td>
                                <td class="text-center">
                                    @if (report.IsResolved)
                                    {
                                        <span class="badge bg-success rounded-circle p-1" title="Vyřešeno">
                                            <i class="bi bi-check-lg text-white"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning rounded-circle p-1" title="Čeká na vyřízení">
                                            <i class="bi bi-clock text-dark"></i>
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-page="./Detail" asp-route-id="@report.Id" class="btn btn-primary btn-sm rounded-pill px-3 fw-bold shadow-sm">
                                        Přejít k řešení
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>