@page
@model Taskify.Pages.Admin.Tasks.IndexModel
@{
    ViewData["Title"] = "Správa úkolů";
}

<link rel="stylesheet" href="~/css/Admin/Users/Index.css" asp-append-version="true" />

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Admin/AdminDashboard" class="text-decoration-none text-muted">Administrace</a></li>
            <li class="breadcrumb-item active fw-bold text-dark">Úkoly</li>
        </ol>
    </nav>

    <h1 class="fw-bold mb-4">Správa úkolů</h1>
    
    <form method="get" id="filterForm" class="mb-5">
        <div class="card shadow-sm border-0 rounded-4 bg-white p-3">
            <div class="row g-3 align-items-center">
                
                <div class="col-lg-4">
                    <div class="input-group bg-light rounded-pill px-3 py-1">
                        <span class="input-group-text bg-transparent border-0">
                            <i class="bi bi-search text-primary"></i>
                        </span>
                        <input type="text" name="SearchQuery" value="@Model.SearchQuery" 
                               class="form-control bg-transparent border-0 shadow-none" 
                               placeholder="Hledat v názvu nebo popisu...">
                    </div>
                </div>
                
                <div class="col-md-6 col-lg-3">
                    <select name="StatusFilter" class="form-select border-0 bg-light rounded-pill shadow-none px-4" onchange="this.form.submit()">
                        <option value="" selected="@(!Model.StatusFilter.HasValue)">Všechny stavy</option>
                        @foreach (var status in Enum.GetValues<Taskify.Models.Enums.TaskStatus>())
                        {
                            <option value="@status" selected="@(Model.StatusFilter == status)">@Model.GetStatusLabel(status)</option>
                        }
                    </select>
                </div>

                <div class="col-lg-1 ms-auto text-end">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm w-100">
                        <i class="bi bi-filter"></i>
                    </button>
                </div>
                
            </div>
        </div>
    </form>
    
    @if (!Model.Tasks.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-list-task text-muted display-1 opacity-25"></i>
            <h4 class="mt-3 text-muted">Žádné úkoly neodpovídají filtrům!</h4>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-0">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Úkol</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Kategorie</th>
                            <th class="py-3 text-uppercase small fw-bold text-muted">Autor</th>
                            <th class="py-3 text-center text-uppercase small fw-bold text-muted">Stav</th>
                            <th class="py-3 text-end pe-4 text-uppercase small fw-bold text-muted">Akce</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var task in Model.Tasks)
                        {
                            <tr class="border-bottom">
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@task.Title</div>
                                    <span class="small text-muted">ID: @task.Id • @task.CreatedAt.ToString("dd.MM.yyyy")</span>
                                </td>
                                <td>
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-pill px-3">
                                        @task.Category?.Name
                                    </span>
                                </td>
                                <td>
                                    <a href="/u/@task.CreatedBy?.UserName" class="text-decoration-none text-dark d-flex align-items-center hover-primary">
                                        <div style="width: 24px; height: 24px; border-radius: 50%; overflow: hidden; background-color: #eee;" class="me-2 shadow-sm hover-lift">
                                            @if (!string.IsNullOrEmpty(task.CreatedBy?.ProfilePictureUrl)) {
                                                <img src="@task.CreatedBy.ProfilePictureUrl" class="w-100 h-100 object-fit-cover" />
                                            }
                                        </div>
                                        <div class="d-flex flex-column lh-1">
                                            <span class="small fw-bold text-dark">@task.CreatedBy?.Name</span>
                                            <small class="text-muted" style="font-size: 0.65rem;">@@@task.CreatedBy?.UserName</small>
                                        </div>
                                    </a>
                                </td>
                                <td class="text-center">
                                    <span class="badge rounded-pill px-3 py-1 @(task.Status switch {
                                        Taskify.Models.Enums.TaskStatus.Open => "bg-success",
                                        Taskify.Models.Enums.TaskStatus.InProgress => "bg-primary",
                                        Taskify.Models.Enums.TaskStatus.Completed => "bg-dark",
                                        Taskify.Models.Enums.TaskStatus.Archived => "bg-secondary",
                                        _ => "bg-warning text-dark"
                                    })">
                                        @Model.GetStatusLabel(task.Status)
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-light btn-sm rounded-circle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-3 p-2">
                                            <li>
                                                <a href="/Tasks/Detail/@task.Id" class="dropdown-item rounded-2 py-2">
                                                    <i class="bi bi-eye me-2 text-primary"></i>Zobrazit detail
                                                </a>
                                            </li>
                                            <li><hr class="dropdown-divider opacity-50"></li>
                                            <li>
                                                <form method="post" asp-page-handler="Delete" asp-route-id="@task.Id" onsubmit="return confirm('Opravdu chcete tento úkol smazat? Tato akce je nevratná.');">
                                                    <button type="submit" class="dropdown-item rounded-2 py-2 text-danger">
                                                        <i class="bi bi-trash3 me-2"></i>Smazat úkol
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>