@page
@model Taskify.Pages.Admin.Tasks.IndexModel
@{
    ViewData["Title"] = "Správa úkolů";
}

<link rel="stylesheet" href="~/css/Admin/Tasks/Index.css" asp-append-version="true" />

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Admin/AdminDashboard" class="text-decoration-none text-muted">Administrace</a></li>
            <li class="breadcrumb-item active fw-bold text-dark">Úkoly</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Správa úkolů</h1>
        <span class="badge bg-primary rounded-pill px-3 py-2">Celkem: @Model.Tasks.Count</span>
    </div>
    
    <form method="get" id="filterForm" class="mb-5">
        <div class="card shadow-sm border-0 rounded-pill bg-white w-auto">
            <div class="card-body p-2">
                <div class="row g-0 align-items-center">
                    
                    <div class="col-lg-4">
                        <div class="input-group border-0">
                            <span class="input-group-text bg-transparent border-0 text-muted ps-3">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" name="SearchQuery" value="@Model.SearchQuery" 
                                   class="form-control border-0 fs-6 shadow-none" placeholder="Hledat v úkolech...">
                        </div>
                    </div>

                    <div class="d-none d-lg-block border-start" style="height: 30px; width: 1px;"></div>
                    
                    <div class="col-lg-4">
                        <div class="dropdown w-100 h-100">
                            <button class="btn btn-lg btn-transparent w-100 text-start border-0 d-flex align-items-center fs-6 shadow-none"
                                    type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-info-circle text-primary me-2"></i>
                                <span class="text-truncate">
                                    @(Model.StatusFilter.HasValue ? Model.GetStatusLabel(Model.StatusFilter.Value) : "Všechny stavy")
                                </span>
                                <i class="bi bi-chevron-down ms-auto small opacity-50"></i>
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 rounded-4 py-2 mt-2 w-100">
                                <li><a class="dropdown-item px-3 @(!Model.StatusFilter.HasValue ? "active" : "")" href="?SearchQuery=@Model.SearchQuery&StatusFilter=">Všechny stavy</a></li>
                                <li><hr class="dropdown-divider opacity-50"></li>
                                @foreach (var status in Enum.GetValues<Taskify.Models.Enums.TaskStatus>())
                                {
                                    <li>
                                        <a class="dropdown-item px-3 @(Model.StatusFilter == status ? "active" : "")" 
                                           href="?SearchQuery=@Model.SearchQuery&StatusFilter=@status">
                                            @Model.GetStatusLabel(status)
                                        </a>
                                    </li>
                                }
                            </ul>
                            <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
    
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-0">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">ID / Datum</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Název a Lokalita</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Autor</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Stav</th>
                        <th class="py-3 text-end pe-4 text-uppercase small fw-bold text-muted">Akce</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var task in Model.Tasks)
                    {
                        <tr class="border-bottom">
                            <td class="ps-4">
                                <div class="fw-bold text-dark">#@task.Id</div>
                                <div class="small text-muted">@task.CreatedAt.ToString("dd.MM.yyyy")</div>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@task.Title</div>
                                <div class="small text-muted">
                                    <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                                    @task.Location.City, @task.Location.Street
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div style="width: 24px; height: 24px; border-radius: 50%; overflow: hidden; background-color: #eee;" class="me-2">
                                        @if (!string.IsNullOrEmpty(task.CreatedBy?.ProfilePictureUrl)) {
                                            <img src="@task.CreatedBy.ProfilePictureUrl" class="w-100 h-100 object-fit-cover" />
                                        }
                                    </div>
                                    <span class="small fw-bold">@task.CreatedBy?.UserName</span>
                                </div>
                            </td>
                            <td>
                                @{
                                    var statusClass = task.Status switch {
                                        Taskify.Models.Enums.TaskStatus.Open => "bg-success",
                                        Taskify.Models.Enums.TaskStatus.InProgress => "bg-primary",
                                        Taskify.Models.Enums.TaskStatus.Completed => "bg-info",
                                        Taskify.Models.Enums.TaskStatus.Archived => "bg-secondary",
                                        _ => "bg-warning"
                                    };
                                }
                                <span class="badge @statusClass bg-opacity-10 text-@statusClass.Replace("bg-", "") border border-@statusClass.Replace("bg-", "")-subtle rounded-pill px-2 py-1 small">
                                    @Model.GetStatusLabel(task.Status)
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-page="/Tasks/Edit" asp-route-id="@task.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold">
                                        <i class="bi bi-pencil me-1"></i> Upravit
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold" 
                                            data-bs-toggle="modal" data-bs-target="#deleteModal-@task.Id">
                                        <i class="bi bi-trash me-1"></i>
                                    </button>
                                </div>

                                <!-- DELETE MODAL FOR EACH TASK -->
                                <div class="modal fade text-start" id="deleteModal-@task.Id" tabindex="-1">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content border-0 shadow-lg rounded-4">
                                            <div class="modal-header border-0 pb-0">
                                                <h5 class="modal-title fw-bold text-danger">Smazat úkol #@task.Id</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body py-4">
                                                Opravdu chcete smazat úkol <strong>@task.Title</strong>? Tato akce je nevratná.
                                            </div>
                                            <div class="modal-footer border-0 pt-0">
                                                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Zrušit</button>
                                                <form method="post" asp-page-handler="Delete" asp-route-id="@task.Id">
                                                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">Smazat</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>