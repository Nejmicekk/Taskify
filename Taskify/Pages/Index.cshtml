@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="~/css/Dashboard/dashboard.css" asp-append-version="true">

<div class="container-fluid py-4">
    <div id="tasks-panel" class="expandable-section mb-4">
        <div class="card shadow-sm border-0 p-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0">Nejnovější úkoly</h4>
                <a asp-page="/Tasks/Index" class="btn btn-primary btn-sm rounded-3">
                    <i class="bi bi-search me-2"></i>Prozkoumat všechny úkoly
                </a>
            </div>
            
            <div class="task-scroll-wrapper d-flex gap-3 pb-3" style="overflow-x: auto;">
                @foreach (var task in Model.Tasks.Take(5)) { 
                    <div class="task-item-dashboard">
                        @Html.AntiForgeryToken()
                        <partial name="_TaskCardPartial" model="task"
                                 view-data='new ViewDataDictionary(ViewData) { { "ShowDescription", false }, { "IsMini", true } }'/>
                    </div>
                }
            </div>
        </div>
    </div>

    <div id="map-panel" class="expandable-section">
        <div class="card shadow-sm border-0 position-relative">
            <div id="map-container" 
                 data-tasks='@Html.Raw(Json.Serialize(Model.Tasks.Select(t => new {
                                 id = User.Identity.IsAuthenticated ? t.Id : 0,
                                 title = User.Identity.IsAuthenticated ? t.Title : "Skrytý úkol - vyžaduje přihlášení",
                                 lat = User.Identity.IsAuthenticated ? t.Location.Latitude : t.Location.Latitude + (new Random().NextDouble() * 0.002), 
                                 lng = User.Identity.IsAuthenticated ? t.Location.Longitude : t.Location.Longitude + (new Random().NextDouble() * 0.002),
                                 category = User.Identity.IsAuthenticated ? t.Category?.Name : "???",
                                 xp = User.Identity.IsAuthenticated ? t.RewardPoints : 0,
                                 imageUrl = t.Images?.FirstOrDefault()?.Url ?? "/images/placeholder-task.png",
                                 isGuest = !User.Identity.IsAuthenticated
                             })))'>
            </div>
            <button class="btn btn-light shadow-sm position-absolute m-3" 
                    onclick="toggleExpand('map-panel')" 
                    style="z-index: 1000; top: 0; right: 0; border: 1px solid #dee2e6;">
                <i class="bi bi-arrows-angle-expand me-2"></i>Zvětšit mapu
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/Dashboard/dashboard.js" asp-append-version="true"></script>
    <script src="~/js/Tasks/_taskCard.js" asp-append-version="true"></script>
    <script src="~/js/Tasks/report_modal.js" asp-append-version="true"></script>
}