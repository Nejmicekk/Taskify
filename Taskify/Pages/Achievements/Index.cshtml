@page
@model Taskify.Pages.Achievements.IndexModel
@{
    ViewData["Title"] = Model.IsMe ? "Moje Achievementy" : $"Achievementy uživatele {Model.TargetUser?.Name}";
}

<link rel="stylesheet" href="~/css/Achievements/Index.css" asp-append-version="true" />

<div class="achievements-page bg-light min-vh-100 pb-5">
    <div class="achievement-header bg-white py-5 mb-4 shadow-sm border-bottom">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-8 text-center text-md-start">
                    <nav aria-label="breadcrumb" class="mb-2">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="/u/@Model.TargetUser?.UserName" class="text-decoration-none">Profil</a></li>
                            <li class="breadcrumb-item active">Achievementy</li>
                        </ol>
                    </nav>
                    <h1 class="fw-bold mb-2 text-dark">
                        @(Model.IsMe ? "Vaše sbírka achievementů" : $"Sbírka achievementů uživatele {Model.TargetUser?.Name}")
                    </h1>
                    <p class="text-muted lead">Celkový pokrok a získané odznaky v aplikaci Taskify.</p>
                </div>
                <div class="col-md-4 mt-3 mt-md-0">
                    <div class="progress-card p-4 rounded-4 bg-primary bg-opacity-10 border border-primary border-opacity-10 shadow-sm text-center">
                        <div class="d-flex justify-content-between mb-2 small fw-bold text-primary">
                            <span>ODEMČENO</span>
                            <span>@Model.UnlockedCount / @Model.TotalCount</span>
                        </div>
                        <div class="progress bg-white mb-2" style="height: 10px; border-radius: 5px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" 
                                 style="width: @Model.TotalProgressPercent.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%;"></div>
                        </div>
                        <span class="badge rounded-pill bg-primary px-3 py-2 mt-1">@Model.TotalProgressPercent.ToString("0")% DOKONČENO</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        @foreach (var group in Model.AchievementGroups)
        {
            <div class="achievement-category-section mb-5">
                <h4 class="fw-bold mb-4 text-dark d-flex align-items-center">
                    <i class="bi bi-collection-fill text-primary me-2"></i>
                    @group.DisplayName
                </h4>

                <div class="row g-3">
                    @foreach (var achVM in group.Achievements)
                    {
                        var isLocked = !achVM.IsUnlocked;
                        var isSecret = achVM.Achievement.IsSecret && isLocked;
                        var rarityClass = achVM.Achievement.Rarity.ToString().ToLower();
                        
                        <div class="col-12">
                            <div class="achievement-card d-flex align-items-center p-3 rounded-4 bg-white shadow-sm border border-light @(isLocked ? "is-locked" : "is-unlocked") rarity-@rarityClass">
                                @* Ikonka *@
                                <div class="achievement-icon-box me-4 rounded-3 d-flex align-items-center justify-content-center rarity-border-@rarityClass">
                                    <img src="@(isSecret ? "/images/achievements/placeholder.svg" : achVM.Achievement.IconUrl)" 
                                         alt="Icon" 
                                         class="achievement-img @(isLocked ? "locked-img" : "")" 
                                         onerror="this.src='/images/achievements/placeholder.svg'"/>
                                </div>
                                
                                <div class="achievement-content flex-grow-1">
                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                        <h5 class="mb-0 fw-bold @(isLocked ? "text-muted" : "text-dark")">
                                            @(isSecret ? "Skrytý achievement" : achVM.Achievement.Name)
                                        </h5>
                                        @if (!isLocked)
                                        {
                                            <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle small px-2">
                                                <i class="bi bi-check-circle-fill me-1"></i>Odemčeno
                                            </span>
                                        }
                                    </div>
                                    <p class="mb-0 text-muted small lead">
                                        @(isSecret ? "Pokračuj v používání aplikace a možná na tento odznak narazíš." : achVM.Achievement.Description)
                                    </p>
                                </div>
                                
                                <div class="achievement-status ms-3 d-none d-md-block text-end" style="min-width: 140px;">
                                    @if (!isLocked)
                                    {
                                        <div class="text-muted extra-small fw-bold text-uppercase">Získáno dne</div>
                                        <div class="fw-bold text-primary">@achVM.UserProgress?.EarnedAt?.ToString("dd.MM.yyyy")</div>
                                    }
                                    else
                                    {
                                        <div class="text-muted small italic">Dosud nezískáno</div>
                                        <span class="badge rounded-pill rarity-badge-@rarityClass small px-2">
                                            @achVM.Achievement.Rarity
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>