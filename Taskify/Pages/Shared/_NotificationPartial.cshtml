@using Taskify.Services
@using Microsoft.AspNetCore.Identity
@using Taskify.Models
@using Taskify.Models.Enums
@inject INotificationService NotificationService
@inject UserManager<User> UserManager

@{
    var userId = UserManager.GetUserId(User);
    var unreadCount = 0;
    List<Notification> recentNotifications = new();

    var isNotificationPage = ViewContext.RouteData.Values["page"]?.ToString() == "/Notifications/Index";

    if (userId != null)
    {
        unreadCount = await NotificationService.GetUnreadCountAsync(userId);
        recentNotifications = await NotificationService.GetRecentNotificationsAsync(userId, 10);
    }

    var now = DateTime.Now;
    var newNotifications = recentNotifications.Where(n => (now - n.CreatedAt).TotalHours < 1).ToList();
    var todayNotifications = recentNotifications.Where(n => (now - n.CreatedAt).TotalHours >= 1 && n.CreatedAt.Date == now.Date).ToList();
    var olderNotifications = recentNotifications.Where(n => n.CreatedAt.Date < now.Date).ToList();
    
    var initialDisplayCount = 5;
    var displayedNew = newNotifications.Take(initialDisplayCount).ToList();
    var displayedToday = todayNotifications.Take(Math.Max(0, initialDisplayCount - displayedNew.Count)).ToList();
    var displayedOlder = olderNotifications.Take(Math.Max(0, initialDisplayCount - displayedNew.Count - displayedToday.Count)).ToList();
}

@if (userId != null)
{
    <li class="nav-item dropdown me-2 list-unstyled">
        <a class="nav-link position-relative no-caret px-3 px-md-2 @(isNotificationPage ? "active-nav-notif disabled" : "dropdown-toggle")" 
           href="#" id="notificationDropdown" role="button" 
           @(isNotificationPage ? "" : "data-bs-toggle=dropdown aria-expanded=false data-bs-auto-close=outside")>
            <i class="bi bi-bell fs-5 @(isNotificationPage ? "text-primary" : "text-dark")"></i>
            <span class="d-md-none ms-2 fw-bold" style="color: #495057;">Oznámení</span>
            @if (unreadCount > 0)
            {
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white d-none d-md-block" id="notificationBadge" style="font-size: 0.65rem; padding: 0.25em 0.5em; margin-top: 5px; margin-left: -5px;">
                    @(unreadCount > 99 ? "99+" : unreadCount)
                </span>
                <span class="badge rounded-pill bg-danger d-md-none ms-auto" id="notificationBadgeMobile">
                    @(unreadCount > 99 ? "99+" : unreadCount)
                </span>
            }
        </a>
        <div class="dropdown-menu dropdown-menu-end shadow-lg border-0 py-0 overflow-hidden mt-2" aria-labelledby="notificationDropdown" style="width: 360px; border-radius: 16px;">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-white">
                <h5 class="mb-0 fw-bold">Oznámení</h5>
                <div class="d-flex align-items-center gap-2">
                    <a asp-page="/Notifications/Index" class="btn btn-sm btn-light rounded-pill px-3 fw-semibold text-primary" style="font-size: 0.8rem;">Zobrazit vše</a>
                    @if (unreadCount > 0)
                    {
                        <button class="btn btn-sm btn-outline-secondary rounded-circle" onclick="markAllAsRead(event)" title="Označit vše jako přečtené">
                            <i class="bi bi-check-all"></i>
                        </button>
                    }
                </div>
            </div>
            
            <div class="notification-container" style="max-height: 450px; overflow-y: auto;">
                <div id="notification-items-list">
                    @if (!recentNotifications.Any())
                    {
                        <div class="p-5 text-center text-muted">
                            <div class="bg-light d-inline-flex p-3 rounded-circle mb-3">
                                <i class="bi bi-bell-slash fs-2"></i>
                            </div>
                            <p class="small fw-medium mb-0">Žádná nová oznámení</p>
                        </div>
                    }
                    else
                    {
                        @if (displayedNew.Any())
                        {
                            <div class="px-3 pt-3 pb-1">
                                <h5 class="fw-bold mb-0 text-dark">Nové</h5>
                            </div>
                            <partial name="_NotificationItemsPartial" model="displayedNew" />
                        }
                        
                        @if (displayedToday.Any())
                        {
                            <div class="px-3 pt-3 pb-1">
                                <h5 class="fw-bold mb-0 text-dark">Dnes</h5>
                            </div>
                            <partial name="_NotificationItemsPartial" model="displayedToday" />
                        }
                        
                        @if (displayedOlder.Any())
                        {
                            <div class="px-3 pt-3 pb-1">
                                <h5 class="fw-bold mb-0 text-dark">Starší</h5>
                            </div>
                            <partial name="_NotificationItemsPartial" model="displayedOlder" />
                        }
                        
                        <div id="loaded-notifications-container"></div>
                    }
                </div>
                
                @if (recentNotifications.Count >= initialDisplayCount)
                {
                    <div class="p-2 border-top text-center" id="load-more-container">
                        <button class="btn btn-sm btn-link text-decoration-none fw-bold w-100 py-2" onclick="loadMoreNotifications(event)" id="loadMoreBtn">
                            Předchozí upozornění
                        </button>
                    </div>
                }
            </div>
        </div>
    </li>
}

<style>
    .active-nav-notif {
        background-color: rgba(13, 110, 253, 0.1);
        border-radius: 50%;
        cursor: default !important;
    }
    .bg-light-blue { background-color: #f0f7ff !important; }
    .notification-item { border-bottom: 1px solid #f0f2f5 !important; }
    .notification-item:hover { background-color: #f8f9fa !important; }
    .no-caret::after { display: none !important; }
    .notification-container::-webkit-scrollbar { width: 6px; }
    .notification-container::-webkit-scrollbar-track { background: transparent; }
    .notification-container::-webkit-scrollbar-thumb { background: #cbd5e0; border-radius: 10px; }
    .notification-container::-webkit-scrollbar-thumb:hover { background: #a0aec0; }
</style>
