<div class="modal fade" id="lockUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-person-x-fill text-danger me-2"></i>Zablokovat účet
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zavřít"></button>
            </div>
            <form method="post" id="lockUserForm" asp-page-handler="ToggleLock">
                <input type="hidden" name="userId" id="lockModalUserId" />
                <div class="modal-body p-4">
                    <p class="text-muted small mb-4">Vyberte, na jak dlouho chcete uživateli zamezit přístup k jeho účtu. Tato akce ho okamžitě odhlásí.</p>
                    
                    <div class="list-group list-group-flush rounded-3 border">
                        <label class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 cursor-pointer">
                            <input class="form-check-input flex-shrink-0" type="radio" name="days" value="1" checked>
                            <span class="d-flex flex-column">
                                <strong class="text-dark">1 den</strong>
                            </span>
                        </label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 cursor-pointer">
                            <input class="form-check-input flex-shrink-0" type="radio" name="days" value="14">
                            <span class="d-flex flex-column">
                                <strong class="text-dark">14 dní</strong>
                            </span>
                        </label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 cursor-pointer">
                            <input class="form-check-input flex-shrink-0" type="radio" name="days" value="30">
                            <span class="d-flex flex-column">
                                <strong class="text-dark">1 měsíc</strong>
                            </span>
                        </label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 cursor-pointer">
                            <input class="form-check-input flex-shrink-0" type="radio" name="days" value="365">
                            <span class="d-flex flex-column">
                                <strong class="text-dark">1 rok</strong>
                            </span>
                        </label>
                        <label class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 cursor-pointer bg-light">
                            <input class="form-check-input flex-shrink-0" type="radio" name="days" value="0">
                            <span class="d-flex flex-column">
                                <strong class="text-danger">Trvale</strong>
                            </span>
                        </label>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Zrušit</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">
                        Potvrdit blokaci
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openLockModal(userId) {
        document.getElementById('lockModalUserId').value = userId;
        var modal = new bootstrap.Modal(document.getElementById('lockUserModal'));
        modal.show();
    }
</script>