@using Taskify.Models.Enums
@using Microsoft.AspNetCore.Identity
@using Taskify.Models
@model List<Taskify.Models.Notification>
@inject UserManager<User> UserManager

@if (Model.Any())
{
    @foreach (var notification in Model)
    {
        <div id="notif-@notification.Id" class="notification-item p-3 border-bottom @(notification.IsRead ? "" : "bg-light-blue")" 
             onclick="markAsRead(@notification.Id, event)" 
             data-url="@notification.TargetUrl"
             style="cursor: pointer; transition: background 0.2s;">
            <div class="d-flex align-items-start">
                <div class="position-relative me-3 flex-shrink-0">
                    @if (notification.SenderId != null)
                    {
                        var sender = notification.Sender;
                        
                        if (sender?.UserName?.ToLower() == "admin" || (sender?.Email?.Contains("admin") ?? false))
                        {
                            <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" 
                                 style="width: 48px; height: 48px; background-color: #dc3545; color: white; font-weight: bold; font-size: 20px; border: 2px solid white;">
                                A
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(sender?.ProfilePictureUrl))
                        {
                            <img src="@sender.ProfilePictureUrl" class="rounded-circle shadow-sm" 
                                 style="width: 48px; height: 48px; object-fit: cover; border: 2px solid white;" alt="Avatar" />
                        }
                        else
                        {
                            <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm bg-primary text-white" 
                                 style="width: 48px; height: 48px; font-weight: bold; font-size: 18px; border: 2px solid white;">
                                @(sender?.Name?.Substring(0, 1).ToUpper() ?? "U")
                            </div>
                        }
                    }
                    else
                    {
                        <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm @GetPriorityBgClass(notification.Priority)" 
                             style="width: 48px; height: 48px; border: 2px solid white; line-height: 0;">
                            <i class="bi @GetPriorityIcon(notification.Priority) fs-4 text-white m-0 p-0"></i>
                        </div>
                    }

                    @if (notification.SenderId != null)
                    {
                        <div class="position-absolute bottom-0 end-0 rounded-circle d-flex align-items-center justify-content-center shadow-sm @GetPriorityBgClass(notification.Priority)" 
                             style="width: 20px; height: 20px; border: 1.5px solid white; transform: translate(15%, 15%); line-height: 0;">
                            <i class="bi @GetPriorityIcon(notification.Priority) text-white m-0 p-0" style="font-size: 0.65rem;"></i>
                        </div>
                    }
                </div>

                @* Content Column *@
                <div class="flex-grow-1 overflow-hidden">
                    <div class="d-flex justify-content-between align-items-start">
                        <span class="fw-bold small pe-2 text-dark" style="font-size: 0.9rem; line-height: 1.2;">@notification.Title</span>
                        <span class="text-muted flex-shrink-0" style="font-size: 0.7rem;">@GetTimeAgo(notification.CreatedAt)</span>
                    </div>
                    <p class="mb-0 small text-secondary text-truncate-2" style="font-size: 0.8rem; line-height: 1.3;">@notification.Message</p>
                </div>

                @* Unread Indicator *@
                @if (!notification.IsRead)
                {
                    <div class="ms-2 mt-2">
                        <span class="badge bg-primary rounded-circle p-1" style="width: 8px; height: 8px;"><span class="visually-hidden">Nepřečteno</span></span>
                    </div>
                }
            </div>
        </div>
    }
}

@functions {
    string GetTimeAgo(DateTime dateTime)
    {
        var span = DateTime.Now - dateTime;
        if (span.TotalMinutes < 1) return "Nyní";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes} m";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} h";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays} d";
        return dateTime.ToString("d. M.");
    }

    string GetPriorityIcon(NotificationPriority priority) => priority switch
    {
        NotificationPriority.Success => "bi-check-lg",
        NotificationPriority.Warning => "bi-exclamation-triangle-fill",
        NotificationPriority.Important => "bi-info-circle-fill",
        _ => "bi-info-lg"
    };

    string GetPriorityBgClass(NotificationPriority priority) => priority switch
    {
        NotificationPriority.Success => "bg-success",
        NotificationPriority.Warning => "bg-warning",
        NotificationPriority.Important => "bg-danger",
        _ => "bg-info"
    };
}

<style>
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
