@model Taskify.Models.TaskItem
@{
    var showDescription = ViewData["ShowDescription"] as bool? ?? true;
    var isMini = ViewData["IsMini"] as bool? ?? false;
    
    var cardPadding = isMini ? "p-3" : "p-4";
    var imageHeight = isMini ? "160px" : "220px";
    var titleSize = isMini ? "fs-5" : "h4";
}

<div class="card h-100 shadow-sm border-0 rounded-4 @cardPadding task-card-hover position-relative overflow-hidden">
    
    <div class="position-absolute top-0 start-0 m-3 z-3">
        <span class="badge bg-success shadow-sm @(isMini ? "px-2 py-1 fs-7" : "px-3 py-2 fs-6") rounded-pill fw-bold">
            @Model.RewardPoints <small class="fw-normal">XP</small>
        </span>
    </div>
    
    <div class="position-relative @(isMini ? "mb-2" : "mb-4")" style="height: @imageHeight;">
        @{
            var images = Model.Images?.ToList();
            var firstImage = images?.FirstOrDefault()?.Url ?? "/images/placeholder-task.png";
        }
        <div class="task-image-container h-100 w-100 rounded-4 overflow-hidden shadow-sm">
            <img src="@firstImage" 
                 class="task-main-img w-100 h-100" 
                 alt="@Model.Title" 
                 style="object-fit: cover; transition: transform 0.5s ease;"
                 @if(!isMini && images != null && images.Count > 1) { 
                     <text>data-images='@Json.Serialize(images.Select(i => i.Url))'</text> 
                 }>
        </div>
    </div>
    
    <div class="flex-grow-1">
        <h4 class="@titleSize fw-bold mb-2 text-truncate-2" style="line-height: 1.4; height: @(isMini ? "2.8rem" : "3.6rem");">
            @Model.Title
        </h4>
        
        <div class="d-flex align-items-center mb-2 text-muted small">
            <i class="bi bi-geo-alt-fill text-danger me-1"></i>
            <span class="fw-medium text-truncate @(!User.Identity.IsAuthenticated ? "blur-content-inline" : "")">
                @if (User.Identity.IsAuthenticated)
                {
                    @($"{Model.Location?.City}, {Model.Location?.Region}")
                }
                else
                {
                    @Model.Location?.Region
                }
            </span>
        </div>
        
        @if (showDescription) {
            <p class="card-text text-muted mb-4 small" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                @Model.Description
            </p>
        }
    </div>
    
    <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
        <div class="text-truncate me-2">
            <div class="text-primary fw-bold mb-1 small text-truncate">
                <i class="bi @(Model.Category?.IconUrl ?? "bi-tag-fill") me-1"></i> @Model.Category?.Name
            </div>
            <div class="text-muted" style="font-size: 0.75rem;">
                <i class="bi bi-clock me-1"></i>
                @(Model.Deadline.HasValue ? Model.Deadline.Value.ToString("dd.MM.yyyy HH:mm") : "Bez termínu")
            </div>
        </div>
        
        <a asp-page="/Tasks/Details" asp-route-id="@Model.Id" 
           class="btn btn-primary fw-bold @(isMini ? "btn-sm px-3" : "px-4 py-2") rounded-pill shadow-sm transition-all flex-shrink-0">
            Detail
        </a>
    </div>
</div>

<div id="map-card-template" class="d-none">
    <div class="map-popup-card" style="width: 250px;">
        <div class="card h-100 shadow-0 border-0 rounded-4 p-2 position-relative overflow-hidden @(User.Identity.IsAuthenticated ? "task-card-hover" : "")">
            
            <div class="@(!User.Identity.IsAuthenticated ? "blur-content" : "")">
                <div class="position-absolute top-0 start-0 m-2 z-3">
                    <span class="badge bg-success shadow-sm px-2 py-1 rounded-pill fw-bold fs-7 t-xp">0 XP</span>
                </div>
                <div class="position-relative mb-2" style="height: 120px;">
                    <img src="" class="t-img w-100 h-100 rounded-3 shadow-sm" style="object-fit: cover;">
                </div>
                <div class="p-1">
                    <h6 class="fw-bold mb-1 text-truncate t-title">Název úkolu</h6>
                    <div class="text-primary fw-bold mb-2" style="font-size: 0.8rem;">
                        <i class="bi bi-tag-fill me-1"></i> <span class="t-category">Kategorie</span>
                    </div>
                </div>
            </div>
            @if (!User.Identity.IsAuthenticated)
            {
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center z-3" style="background: rgba(255,255,255,0.2);">
                    <i class="bi bi-lock-fill text-primary fs-2 mb-4"></i>
                </div>
            }
            <div class="p-1 z-3">
                <a href="" class="btn btn-primary btn-sm w-100 rounded-pill fw-bold t-link">Detail</a>
            </div>
        </div>
    </div>
</div>