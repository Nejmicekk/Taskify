@page
@model Taskify.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = "Úkoly";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="container-fluid pt-3">
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body d-flex gap-3 align-items-center">
            <div class="flex-grow-1">
                <input type="text" class="form-control" placeholder="Hledat úkol..." id="searchQuery">
            </div>
            <select class="form-select w-auto" id="categoryFilter">
                <option value="">Všechny kategorie</option>
                @foreach (var cat in Model.Categories.Where(c => c.LevelNumber == 1)) {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
            <button class="btn btn-primary px-4" id="btn-apply-filters">Hledat</button>
        </div>
    </div>

    <div class="row g-0 border rounded-3 overflow-hidden shadow-sm" style="height: 75vh;">
        <div class="col-md-4 bg-white overflow-auto h-100 border-end" id="task-list-panel">
            <div class="p-3">
                <h5 class="fw-bold mb-3">Nalezené úkoly (<span id="task-count">@Model.Tasks.Count</span>)</h5>
                <div id="tasks-container">
                    @foreach (var task in Model.Tasks) {
                        <div class="mb-3 task-item-wrapper" data-category="@task.CategoryId" data-title="@task.Title.ToLower()">
                            <partial name="_TaskCardPartial" model="task" />
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8 h-100">
            <div id="explore-map" class="h-100" 
                 data-tasks='@Html.Raw(Json.Serialize(Model.Tasks.Select(t => new {
                    t.Id,
                    t.Title,
                    lat = t.Location.Latitude,
                    lng = t.Location.Longitude,
                    catId = t.CategoryId
                 })))'>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/Tasks/explore.js" asp-append-version="true"></script>
}