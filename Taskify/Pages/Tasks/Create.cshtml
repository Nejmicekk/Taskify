@page
@model Taskify.Pages.Tasks.CreateModel
@{
    ViewData["Title"] = "Zadat nový úkol";

    var selectedCatName = "";
    if (Model.Input.CategoryId.HasValue && Model.Input.CategoryId.Value > 0)
    {
        var selectedCat = Model.Categories.FirstOrDefault(c => c.Id == Model.Input.CategoryId.Value);
        if (selectedCat != null) selectedCatName = selectedCat.Name;
    }
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/air-datepicker@3.3.5/air-datepicker.min.css">
<link rel="stylesheet" href="~/css/Tasks/create.css" asp-append-version="true">
<link rel="stylesheet" href="~/css/Tasks/air-datepicker.css" asp-append-version="true">

<div class="container-fluid px-lg-5 mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            
            <div class="mb-4">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2">
                        <li class="breadcrumb-item"><a asp-page="/Index" class="text-decoration-none text-muted">Domů</a></li>
                        <li class="breadcrumb-item active fw-bold text-primary">Zadat nový úkol</li>
                    </ol>
                </nav>
                <h1 class="fw-bold display-5">Vytvořit nový úkol</h1>
                <p class="text-muted fs-5">Popište problém, nahrajte fotky a dejte vědět ostatním, kde je potřeba pomoct.</p>
            </div>

            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 border-0 shadow-sm mb-4" role="alert"></div>

                <div class="row g-4">
                    @* Levý sloupec - Detaily *@
                    <div class="col-xl-6">
                        <div class="card border-0 shadow-sm rounded-4 h-100 overflow-visible">
                            <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                                <h4 class="fw-bold mb-0"><i class="bi bi-info-circle me-2 text-primary"></i>Základní informace</h4>
                            </div>
                            <div class="card-body p-4">
                                <div class="form-floating mb-3">
                                    <input asp-for="Input.Title" class="form-control rounded-3" placeholder="Název úkolu" />
                                    <label asp-for="Input.Title">Název úkolu (např. Rozbitá lavička)</label>
                                    <span asp-validation-for="Input.Title" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3">
                                    <textarea asp-for="Input.Description" class="form-control rounded-3" placeholder="Popis problému" style="height: 120px"></textarea>
                                    <label asp-for="Input.Description">Podrobný popis</label>
                                    <span asp-validation-for="Input.Description" class="text-danger small"></span>
                                </div>

                                <div class="form-floating mb-3 dropdown" id="categoryDropdownWrapper">
                                    <input type="text" id="categoryDropdownBtn" class="form-control bg-white rounded-3" 
                                           data-bs-toggle="dropdown" data-bs-auto-close="outside"
                                           autocomplete="off" value="@selectedCatName" readonly style="cursor: pointer;" placeholder="Kategorie">
                                    <label for="categoryDropdownBtn">Vyberte kategorii</label>
                                    <input type="hidden" asp-for="Input.CategoryId" id="hiddenCategoryId" />
                                    <span asp-validation-for="Input.CategoryId" class="text-danger small"></span>

                                    <ul class="dropdown-menu w-100 p-0 shadow-lg border-0 rounded-4 overflow-hidden category-dropdown-menu scroll-y" style="max-height: 400px;">
                                        <li class="p-3 bg-light border-bottom sticky-top">
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                                                <input type="text" id="categorySearch" class="form-control border-start-0" placeholder="Hledat kategorii...">
                                            </div>
                                        </li>
                                        @foreach (var l1 in Model.Categories.Where(c => c.ParentId == null))
                                        {
                                            <li class="parent-li border-bottom">
                                                <div class="d-flex align-items-center category-header bg-light p-0">
                                                    <div class="p-3 flex-grow-1 category-item cursor-pointer" data-id="@l1.Id" data-name="@l1.Name">
                                                        <i class="bi @(l1.IconUrl ?? "bi-folder") me-2 fs-5 text-primary"></i>
                                                        <span class="fw-bold">@l1.Name</span>
                                                    </div>
                                                    <div class="p-3 border-start" data-bs-toggle="collapse" data-bs-target="#cat-@l1.Id" style="cursor:pointer">
                                                        <i class="bi bi-chevron-down text-muted chevron-icon"></i>
                                                    </div>
                                                </div>

                                                <ul class="collapse list-unstyled mb-0" id="cat-@l1.Id">
                                                    @foreach (var l2 in Model.Categories.Where(c => c.ParentId == l1.Id))
                                                    {
                                                        var l3Categories = Model.Categories.Where(c => c.ParentId == l2.Id).ToList();
                                                        <li class="parent-li border-top">
                                                            <div class="d-flex align-items-center category-header p-0">
                                                                <div class="p-2 ps-4 flex-grow-1 category-item cursor-pointer text-muted" data-id="@l2.Id" data-name="@l2.Name">
                                                                    <i class="bi @(l2.IconUrl ?? "bi-folder2") me-2 text-secondary"></i> @l2.Name
                                                                </div>
                                                                @if (l3Categories.Any())
                                                                {
                                                                    <div class="p-2 border-start" data-bs-toggle="collapse" data-bs-target="#cat-@l2.Id" style="cursor:pointer">
                                                                        <i class="bi bi-chevron-down text-muted chevron-icon" style="font-size: 0.8rem;"></i>
                                                                    </div>
                                                                }
                                                            </div>
                                                            @if (l3Categories.Any())
                                                            {
                                                                <ul class="collapse list-unstyled mb-0 bg-white" id="cat-@l2.Id">
                                                                    @foreach (var l3 in l3Categories)
                                                                    {
                                                                        <li class="category-item category-leaf-li border-top p-2 ps-5 text-muted cursor-pointer" data-id="@l3.Id" data-name="@l3.Name" data-search="@l1.Name @l2.Name @l3.Name">
                                                                            <i class="bi @(l3.IconUrl ?? "bi-dot") me-2"></i> @l3.Name
                                                                        </li>
                                                                    }
                                                                </ul>
                                                            }
                                                        </li>
                                                    }
                                                </ul>
                                            </li>
                                        }
                                    </ul>
                                </div>

                                <div class="form-floating mb-3">
                                    <input type="text" id="deadline-display" class="form-control rounded-3 bg-white" placeholder="Termín splnění" readonly style="cursor: pointer;" />
                                    <label for="deadline-display">Termín splnění (nepovinné)</label>
                                    <input type="hidden" asp-for="Input.Deadline" id="deadline-picker" />
                                </div>

                                <div class="mb-0">
                                    <label class="form-label small fw-bold text-muted text-uppercase mb-2"><i class="bi bi-images me-1"></i>Fotografie (max 10)</label>
                                    <div class="upload-zone border border-2 border-dashed rounded-4 p-4 text-center bg-light" id="dropzone" style="cursor: pointer" onclick="document.getElementById('imageUploads').click()">
                                        <input type="file" name="imageUploads" id="imageUploads" multiple accept="image/*" class="d-none" />
                                        <div class="icon-circle bg-white shadow-sm mb-3 mx-auto" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; border-radius: 50%;">
                                            <i class="bi bi-cloud-arrow-up fs-3 text-primary"></i>
                                        </div>
                                        <p class="mb-1 fw-bold small">Klikněte pro výběr fotek</p>
                                        <p class="text-muted" style="font-size: 0.7rem">nebo je přetáhněte sem</p>
                                        <div id="imagePreview" class="row row-cols-3 g-2 mt-3"></div>
                                    </div>
                                    <span class="text-danger small">@Html.ValidationMessage("Input.ImageUploadsValidation")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Pravý sloupec - Lokalita *@
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                            <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                                <h4 class="fw-bold mb-0"><i class="bi bi-geo-alt-fill me-2 text-danger"></i>Kde je problém?</h4>
                            </div>
                            <div class="card-body p-4 d-flex flex-column">
                                <div class="input-group mb-3 shadow-sm rounded-pill overflow-hidden border">
                                    <span class="input-group-text bg-white border-0 ps-3"><i class="bi bi-search text-muted"></i></span>
                                    <input type="text" id="address-search" class="form-control border-0 px-2 py-2" placeholder="Hledat adresu...">
                                    <button class="btn btn-primary px-4 fw-bold no-anim" type="button" id="btn-search">Najít</button>
                                </div>

                                <div id="map" class="rounded-4 border shadow-inner flex-grow-1 mb-3" style="min-height: 450px; z-index: 1;"></div>
                                
                                <div class="p-3 bg-light rounded-4 border-0">
                                    <div class="d-flex align-items-center text-muted mb-1">
                                        <i class="bi bi-pin-map-fill me-2"></i>
                                        <span class="small fw-bold text-uppercase" style="font-size: 0.65rem">Aktuálně vybraná adresa:</span>
                                    </div>
                                    <p id="current-address-text" class="mb-0 fw-bold text-dark small">Klikněte do mapy...</p>
                                </div>

                                <input type="hidden" asp-for="Input.LocationLatitude" id="lat-input" />
                                <input type="hidden" asp-for="Input.LocationLongitude" id="lng-input" />
                                <input type="hidden" asp-for="Input.FullAddress" id="full-address-input" />
                                <input type="hidden" asp-for="Input.Region" id="region-input" />
                                <input type="hidden" asp-for="Input.City" id="city-input" />
                                <input type="hidden" asp-for="Input.Street" id="street-input" />
                                <input type="hidden" asp-for="Input.StreetNumber" id="street-number-input" />
                                <input type="hidden" asp-for="Input.PostCode" id="postcode-input" />
                                <span asp-validation-for="Input.LocationLatitude" class="text-danger small mt-2 d-block"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-5">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 py-3 fw-bold shadow-lg hover-lift no-anim">
                        <i class="bi bi-plus-circle me-2"></i> Zveřejnit úkol
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/air-datepicker@3.3.5/air-datepicker.min.js"></script>
    <script src="~/js/Tasks/_localeCs.js" asp-append-version="true"></script>
    <script src="~/js/Tasks/create.js" asp-append-version="true"></script>
    <script src="~/js/categories-dropdown.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const fullAddressInput = document.getElementById('full-address-input');
            const currentAddressText = document.getElementById('current-address-text');
            
            setInterval(() => {
                if (fullAddressInput.value) {
                    currentAddressText.innerText = fullAddressInput.value;
                }
            }, 500);
        });
    </script>
}