@page "{id:int}"
@model Taskify.Pages.Tasks.EditModel
@{
    ViewData["Title"] = "Upravit úkol";
    var images = Model.DisplayTask.Images.ToList();

    var selectedCatName = "";
    if (Model.Input.CategoryId > 0)
    {
        var selectedCat = Model.Categories.FirstOrDefault(c => c.Id == Model.Input.CategoryId);
        if (selectedCat != null) selectedCatName = selectedCat.Name;
    }
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="~/css/Tasks/detail.css" asp-append-version="true">
<link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/air-datepicker@3.3.5/air-datepicker.min.css">
<link rel="stylesheet" href="~/css/Tasks/create.css" asp-append-version="true">
<link rel="stylesheet" href="~/css/Tasks/air-datepicker.css" asp-append-version="true">

<div class="container mt-4 mb-5">
    
    <div class="mb-4">
        <a asp-page="/Tasks/Detail" asp-route-id="@Model.Input.Id" class="text-decoration-none text-secondary mb-2 d-inline-block fw-bold">
            <i class="bi bi-arrow-left me-1"></i> Zpět na detail úkolu
        </a>
        <h2 class="fw-bold"><i class="bi bi-pencil-square text-primary me-2"></i>@ViewData["Title"]</h2>
        <p class="text-muted mb-0">Upravte texty, termín nebo kategorii. Lokaci a fotky nelze měnit.</p>
    </div>

    <div class="row g-5">
        
        <div class="col-lg-7 d-none d-lg-block">
            <div id="taskGallery" class="carousel slide shadow-sm rounded-4 overflow-hidden bg-black position-relative" data-bs-ride="false">
                <div class="position-absolute top-0 end-0 m-3 z-3">
                    <span class="badge bg-light text-success border border-success shadow px-3 py-2 rounded-pill fs-6 fw-bold">
                        <i class="bi bi-star-fill me-1"></i> @Model.DisplayTask.RewardPoints XP
                    </span>
                </div>

                <div class="carousel-inner h-100" style="height: 400px">
                    @if (images.Any())
                    {
                        for (int i = 0; i < images.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@images[i].Url" class="d-block w-100" style="height: 400px; object-fit: cover;" alt="Obrázek úkolu">
                            </div>
                        }
                    }
                    else
                    {
                        <div class="carousel-item active">
                            <img src="/images/task-placeholder.svg" class="d-block w-100" style="height: 500px; object-fit: cover;" alt="Placeholder">
                        </div>
                    }
                </div>

                @if (images.Count > 1)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#taskGallery" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon p-3 bg-dark rounded-circle" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#taskGallery" data-bs-slide="next">
                        <span class="carousel-control-next-icon p-3 bg-dark rounded-circle" aria-hidden="true"></span>
                    </button>
                    <div class="position-absolute bottom-0 start-50 translate-middle-x mb-2">
                        <span class="badge bg-dark bg-opacity-50 px-3 py-1 rounded-pill small">
                            <span id="carousel-index">1</span> / @images.Count
                        </span>
                    </div>
                }
            </div>
            
            <div class="d-flex align-items-center mb-3 mt-4">
                <h5 class="fw-bold mb-0">Přesná lokalita úkolu</h5>
            </div>
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div id="detailMap" 
                     style="height: 400px; z-index: 1;"
                     data-lat="@Model.DisplayTask.Location.Latitude" 
                     data-lng="@Model.DisplayTask.Location.Longitude"
                     data-title="@Model.DisplayTask.Title">
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <form method="post" class="h-100 d-flex flex-column">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Input.Id" />

                <div class="card shadow-sm border-0 rounded-4 flex-grow-1">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Upravit podrobnosti</h5>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.Title" class="form-control" placeholder="Název" />
                            <label asp-for="Input.Title"></label>
                            <span asp-validation-for="Input.Title" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="form-floating mb-4 dropdown" id="categoryDropdownWrapper">
                            <input type="text" id="categorySearchInput" class="form-control bg-white"
                                   data-bs-toggle="dropdown" data-bs-auto-close="outside"
                                   autocomplete="off" value="@selectedCatName" readonly style="cursor: pointer;">
                            <label asp-for="Input.CategoryId">Kategorie</label>
                            <input type="hidden" asp-for="Input.CategoryId" id="hiddenCategoryId">
                            <span asp-validation-for="Input.CategoryId" class="text-danger small fw-bold"></span>

                            <ul class="dropdown-menu w-100 p-0 shadow-lg category-dropdown-menu scroll-y" style="max-height: 400px;">
                                @foreach (var l1 in Model.Categories.Where(c => c.LevelNumber == 1).OrderBy(c => c.Name))
                                {
                                    <li class="parent-li border-bottom">
                                        <div class="d-flex align-items-center category-header bg-light p-0">
                                            <div class="p-3 flex-grow-1 category-item cursor-pointer" data-id="@l1.Id" data-name="@l1.Name">
                                                <i class="bi @l1.IconUrl me-2 fs-5 text-primary"></i>
                                                <span class="fw-bold">@l1.Name</span>
                                            </div>
                                            <div class="p-3 border-start" data-bs-toggle="collapse" data-bs-target="#cat-@l1.Id" style="cursor:pointer">
                                                <i class="bi bi-chevron-down text-muted chevron-icon"></i>
                                            </div>
                                        </div>

                                        <ul class="collapse list-unstyled mb-0" id="cat-@l1.Id">
                                            @foreach (var l2 in Model.Categories.Where(c => c.ParentId == l1.Id).OrderBy(c => c.Name))
                                            {
                                                var l3Cats = Model.Categories.Where(c => c.ParentId == l2.Id).OrderBy(c => c.Name).ToList();
                                                <li class="parent-li border-top">
                                                    <div class="d-flex align-items-center category-header p-0">
                                                        <div class="p-2 ps-4 flex-grow-1 category-item @(!l3Cats.Any() ? "category-leaf-li" : "") cursor-pointer text-muted" data-id="@l2.Id" data-name="@l2.Name" data-search="@l1.Name @l2.Name">
                                                            <i class="bi @l2.IconUrl me-2 text-secondary"></i> @l2.Name
                                                        </div>
                                                        @if (l3Cats.Any())
                                                        {
                                                            <div class="p-2 border-start" data-bs-toggle="collapse" data-bs-target="#cat-@l2.Id" style="cursor:pointer">
                                                                <i class="bi bi-chevron-down text-muted chevron-icon" style="font-size: 0.8rem;"></i>
                                                            </div>
                                                        }
                                                    </div>
                                                    @if (l3Cats.Any())
                                                    {
                                                        <ul class="collapse list-unstyled mb-0 bg-white" id="cat-@l2.Id">
                                                            @foreach (var l3 in l3Cats)
                                                            {
                                                                <li class="category-item category-leaf-li border-top p-2 ps-5 text-muted cursor-pointer" data-id="@l3.Id" data-name="@l3.Name" data-search="@l1.Name @l2.Name @l3.Name">
                                                                    <i class="bi @l3.IconUrl me-2"></i> @l3.Name
                                                                </li>
                                                            }
                                                        </ul>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    </li>
                                }
                            </ul>
                        </div>

                        <div class="form-floating mb-4 flex-grow-1">
                            <textarea asp-for="Input.Description" class="form-control h-100" style="min-height: 150px" placeholder="Popis"></textarea>
                            <label asp-for="Input.Description"></label>
                            <span asp-validation-for="Input.Description" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="form-floating mb-4">
                            @{
                                var dateString = Model.Input.Deadline.HasValue ? Model.Input.Deadline.Value.ToString("dd.MM.yyyy HH:mm") : "";
                            }
                            <input type="text" id="deadline-display" class="form-control bg-white" readonly style="cursor: pointer;" placeholder="Termín splnění" value="@dateString" />
                            <label for="deadline-display">Termín splnění (volitelné)</label>

                            <input type="hidden" asp-for="Input.Deadline" id="deadline-picker" value="@(Model.Input.Deadline?.ToString("yyyy-MM-ddTHH:mm"))" />
                            <span asp-validation-for="Input.Deadline" class="text-danger small fw-bold"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 mt-auto fw-bold shadow-sm rounded-pill text-dark">
                            <i class="bi bi-save-fill me-2"></i> Uložit změny
                        </button>
                        
                        <button type="button" class="btn btn-outline-danger w-100 py-3 mt-3 fw-bold shadow-sm rounded-pill" data-bs-toggle="modal" data-bs-target="#deleteModal">
                            <i class="bi bi-trash3-fill me-2"></i> Smazat úkol
                        </button>
                        
                        <div class="text-center mt-3">
                            <a asp-page="/Tasks/Detail" asp-route-id="@Model.Input.Id" class="text-muted text-decoration-none small fw-bold">
                                Zrušit úpravy
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>


<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger" id="deleteModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Smazat úkol
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <p class="mb-0 text-dark">Opravdu chcete tento úkol trvale smazat? Tuto akci <strong>nelze</strong> vzít zpět.</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Zrušit</button>
                
                <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Input.Id" class="m-0 p-0">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">
                        Ano
                    </button>
                </form>
                
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/air-datepicker@3.3.5/air-datepicker.min.js"></script>
    
    <script src="~/js/Tasks/_localeCs.js" asp-append-version="true"></script>
    <script src="~/js/Tasks/detail.js" asp-append-version="true"></script>
    <script src="~/js/Tasks/edit.js" asp-append-version="true"></script>
    <script src="~/js/categories-dropdown.js" asp-append-version="true"></script>
}