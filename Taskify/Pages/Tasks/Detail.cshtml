@page "{id:int}"
@model Taskify.Pages.Tasks.DetailsModel
@{
    ViewData["Title"] = Model.TaskItem.Title;
    var images = Model.TaskItem.Images.ToList();
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="~/css/Tasks/detail.css" asp-append-version="true">

<div class="container mt-4 mb-5">
    <div class="row g-5">
        
        <div class="col-lg-7">
            
            <div class="d-lg-none mb-4">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h1 class="h3 fw-bold mb-0 pe-2">@Model.TaskItem.Title</h1>
                    <span class="badge @Model.StatusBadgeClass shadow-sm px-3 py-2 rounded-pill flex-shrink-0">
                        @Model.StatusBadgeText
                    </span>
                </div>
            </div>

            <div id="taskGallery" class="carousel slide shadow-sm rounded-4 overflow-hidden bg-black position-relative" data-bs-ride="false">
                <div class="position-absolute top-0 end-0 m-3 z-3">
                    <span class="badge bg-light text-success border border-success shadow px-3 py-2 rounded-pill fs-6 fw-bold">
                        <i class="bi bi-star-fill me-1"></i> @Model.TaskItem.RewardPoints XP
                    </span>
                </div>

                <div class="carousel-inner h-100" style="height: 400px">
                    @if (images.Any())
                    {
                        for (int i = 0; i < images.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@images[i].Url" class="d-block w-100" style="height: 400px; object-fit: cover;" alt="Obrázek úkolu">
                            </div>
                        }
                    }
                    else
                    {
                        <div class="carousel-item active">
                            <img src="/images/placeholder-task.png" class="d-block w-100" style="height: 500px; object-fit: cover;" alt="Placeholder">
                        </div>
                    }
                </div>

                @if (images.Count > 1)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#taskGallery" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon p-3 bg-dark rounded-circle" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#taskGallery" data-bs-slide="next">
                        <span class="carousel-control-next-icon p-3 bg-dark rounded-circle" aria-hidden="true"></span>
                    </button>
                    
                    <div class="position-absolute bottom-0 start-50 translate-middle-x mb-2">
                        <span class="badge bg-dark bg-opacity-50 px-3 py-1 rounded-pill small">
                            <span id="carousel-index">1</span> / @images.Count
                        </span>
                    </div>
                }
            </div>
            
            <div class="d-flex align-items-center mb-3 mt-4">
                <h5 class="fw-bold mb-0">Přesná lokalita úkolu</h5>
            </div>
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div id="detailMap" 
                     style="height: 400px; z-index: 1;"
                     data-lat="@Model.TaskItem.Location.Latitude" 
                     data-lng="@Model.TaskItem.Location.Longitude"
                     data-title="@Model.TaskItem.Title">
                </div>
            </div>
            
        </div>

        <div class="col-lg-5">
            
            <div class="d-none d-lg-block mb-4">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h1 class="h2 fw-bold mb-0 pe-2">@Model.TaskItem.Title</h1>
                    <span class="badge @Model.StatusBadgeClass shadow-sm px-3 py-2 rounded-pill flex-shrink-0">
                        @Model.StatusBadgeText
                    </span>
                </div>
            </div>

            <h5 class="fw-bold mb-3">Podrobnosti úkolu</h5>
            <div class="card border-0 shadow-sm rounded-4 mb-3">
                <div class="card-body p-3">
                    <div class="d-flex align-items-center mb-1">
                        <i class="bi bi-geo-alt-fill text-danger me-2"></i>
                        <span class="small fw-bold text-muted text-uppercase">Lokalita</span>
                    </div>
                    <p class="mb-0 fw-bold text-dark">
                        @($"{Model.TaskItem.Location.Street} {Model.TaskItem.Location.StreetNumber}, {Model.TaskItem.Location.City}, {Model.TaskItem.Location.PostCode}")
                    </p>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center mb-1">
                                <i class="bi bi-calendar-plus text-primary me-2"></i>
                                <span class="small fw-bold text-muted text-uppercase">Vytvořeno</span>
                            </div>
                            <span class="text-dark fw-bold d-block">@Model.TimeAgo</span>
                            <span class="text-muted small">@Model.TaskItem.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center mb-1">
                                <i class="bi bi-clock-history text-warning me-2"></i>
                                <span class="small fw-bold text-muted text-uppercase">Termín splnění</span>
                            </div>
                            @if (Model.TaskItem.Deadline.HasValue)
                            {
                                <span class="text-dark fw-bold d-block">@Model.TimeLeft</span>
                                <span class="text-muted small">@Model.TaskItem.Deadline.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                            }
                            else
                            {
                                <span class="text-dark fw-bold d-block">Není určen</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <h5 class="fw-bold mb-3">Zapojení lidé</h5>
            <div class="row g-3 mb-4">
                <div class="col-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-person-fill text-info me-2"></i>
                                <span class="small fw-bold text-muted text-uppercase">Autor úkolu</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <a asp-page="/Users/UserProfile" asp-route-username="@Model.TaskItem.CreatedBy.UserName" style="width: 32px; height: 32px; border-radius: 50%; overflow: hidden; background-color: #0d6efd; color: white; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: bold;" class="me-2 shadow-sm hover-lift text-decoration-none">
                                    @if (!string.IsNullOrEmpty(Model.TaskItem.CreatedBy.ProfilePictureUrl))
                                    {
                                        <img src="@Model.TaskItem.CreatedBy.ProfilePictureUrl" style="width: 100%; height: 100%; object-fit: cover;" alt="Avatar" />
                                    }
                                    else
                                    {
                                        @(Model.TaskItem.CreatedBy.Name?.Substring(0, 1).ToUpper() ?? "U")
                                    }
                                </a>
                                <div class="d-flex flex-column text-truncate">
                                    <a asp-page="/Users/UserProfile" asp-route-username="@Model.TaskItem.CreatedBy.UserName" class="text-decoration-none text-dark fw-bold hover-primary lh-sm small">
                                        @Model.TaskItem.CreatedBy.Name
                                    </a>
                                    <small class="text-muted" style="font-size: 0.7rem;">@@@Model.TaskItem.CreatedBy.UserName</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-person-arms-up text-success me-2"></i>
                                <span class="small fw-bold text-muted text-uppercase">Dobrovolník</span>
                            </div>
                            @if (Model.TaskItem.AssignedTo != null)
                            {
                                <div class="d-flex align-items-center">
                                    <a asp-page="/Users/UserProfile" asp-route-username="@Model.TaskItem.AssignedTo.UserName" style="width: 32px; height: 32px; border-radius: 50%; overflow: hidden; background-color: #198754; color: white; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: bold;" class="me-2 shadow-sm hover-lift text-decoration-none">
                                        @if (!string.IsNullOrEmpty(Model.TaskItem.AssignedTo.ProfilePictureUrl))
                                        {
                                            <img src="@Model.TaskItem.AssignedTo.ProfilePictureUrl" style="width: 100%; height: 100%; object-fit: cover;" alt="Avatar" />
                                        }
                                        else
                                        {
                                            @(Model.TaskItem.AssignedTo.Name?.Substring(0, 1).ToUpper() ?? "U")
                                        }
                                    </a>
                                    <div class="d-flex flex-column text-truncate">
                                        <a asp-page="/Users/UserProfile" asp-route-username="@Model.TaskItem.AssignedTo.UserName" class="text-decoration-none text-dark fw-bold hover-primary lh-sm small">
                                            @Model.TaskItem.AssignedTo.Name
                                        </a>
                                        <small class="text-muted" style="font-size: 0.7rem;">@@@Model.TaskItem.AssignedTo.UserName</small>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small italic">Očekává dobrovolníka</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <h5 class="fw-bold mb-3">Kategorie</h5>
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-3 d-flex align-items-center">
                    <i class="bi @(Model.TaskItem.Category?.IconUrl ?? "bi-tag") me-2 fs-5 text-primary"></i>
                    <span class="fw-bold">@Model.TaskItem.Category?.Name</span>
                </div>
            </div>

            <h5 class="fw-bold mb-2">Popis problému</h5>
            <div class="card border-0 bg-light rounded-4 mb-4 p-3">
                <p class="text-dark mb-0" style="line-height: 1.6;">@Model.TaskItem.Description</p>
            </div>
            
            @if (User.IsInRole("Admin"))
            {
                <div class="alert bg-danger bg-opacity-10 border-danger border-opacity-25 rounded-4 p-4 mb-4 shadow-sm">
                    <div class="d-flex flex-column flex-sm-row align-items-center justify-content-between gap-3">
                        <div class="d-flex align-items-center text-center text-sm-start">
                            <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center me-sm-3 mb-2 mb-sm-0" style="width: 45px; height: 45px; flex-shrink: 0;">
                                <i class="bi bi-shield-lock-fill fs-5"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold text-danger mb-0">Administrátorská zóna</h6>
                                <p class="small text-muted mb-0">Máte oprávnění tento úkol trvale odstranit ze systému.</p>
                            </div>
                        </div>
                        <button type="button" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#deleteTaskModal">
                            <i class="bi bi-trash3 me-2"></i>
                            <span style="white-space: nowrap;">Smazat úkol</span>
                        </button>
                    </div>
                </div>

                @* Modal pro smazání *@
                <div class="modal fade" id="deleteTaskModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content rounded-4 border-0 shadow-lg">
                            <div class="modal-header border-0 pb-0">
                                <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Smazat úkol?</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zavřít"></button>
                            </div>
                            <div class="modal-body p-4">
                                <p class="text-muted mb-0">Opravdu si přejete smazat tento úkol? Tato akce je nevratná a úkol zmizí všem uživatelům i z mapy.</p>
                            </div>
                            <div class="modal-footer border-0 p-4 pt-0">
                                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Zrušit</button>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@Model.TaskItem.Id">
                                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">Ano, smazat úkol</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (Model.IsMyTask)
            {
                <div class="alert bg-warning bg-opacity-10 border-warning border-opacity-25 rounded-4 p-4 mb-4 shadow-sm">
                    <div class="d-flex flex-column flex-sm-row align-items-center justify-content-between gap-3">
                        <div class="d-flex align-items-center text-center text-sm-start">
                            <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center me-sm-3 mb-2 mb-sm-0" style="width: 45px; height: 45px; flex-shrink: 0;">
                                <i class="bi bi-person-gear fs-5"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold text-dark mb-0">Správa vlastního úkolu</h6>
                                <p class="small text-muted mb-0">Jako autor můžete svůj úkol kdykoliv smazat.</p>
                            </div>
                        </div>
                        <button type="button" class="btn btn-outline-danger rounded-pill px-4 fw-bold shadow-sm d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#deleteTaskModal">
                            <i class="bi bi-trash3 me-2"></i>
                            <span style="white-space: nowrap;">Smazat úkol</span>
                        </button>
                    </div>
                </div>
                
                <div class="modal fade" id="deleteTaskModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content rounded-4 border-0 shadow-lg">
                            <div class="modal-header border-0 pb-0">
                                <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Smazat vlastní úkol?</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zavřít"></button>
                            </div>
                            <div class="modal-body p-4">
                                <p class="text-muted mb-0">Opravdu si přejete smazat svůj úkol? Tato akce je nevratná.</p>
                            </div>
                            <div class="modal-footer border-0 p-4 pt-0">
                                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Zrušit</button>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@Model.TaskItem.Id">
                                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">Ano, smazat úkol</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (Model.IsMyTask)
            {
                if (Model.TaskItem.Status == Models.Enums.TaskStatus.Open)
                {
                    <a asp-page="/Tasks/Edit" asp-route-id="@Model.TaskItem.Id" asp-route-returnUrl="@HttpContext.Request.Query["returnUrl"]" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm mt-auto text-dark">
                        <i class="bi bi-pencil-square me-2"></i> Upravit úkol
                    </a>
                }
                else if (Model.TaskItem.Status == Models.Enums.TaskStatus.InProgress)
                {
                    <button class="btn btn-secondary w-100 py-3 rounded-pill fw-bold shadow-sm mt-auto" disabled>
                        <i class="bi bi-hourglass-split me-2"></i> Dobrovolník na úkolu pracuje
                    </button>
                }
                else if (Model.TaskItem.Status == Models.Enums.TaskStatus.WaitingForReview)
                {
                    <form method="post" asp-page-handler="Approve" asp-route-id="@Model.TaskItem.Id" class="mt-auto">
                        <button type="submit" class="btn btn-success w-100 py-3 rounded-pill fw-bold shadow-sm">
                            <i class="bi bi-check-circle-fill me-2"></i> Schválit vyřešení
                        </button>
                    </form>
                }
                else if (Model.TaskItem.Status == Models.Enums.TaskStatus.Completed)
                {
                    <button class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm mt-auto opacity-75" disabled>
                        <i class="bi bi-trophy-fill me-2"></i> Úkol je úspěšně uzavřen
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary w-100 py-3 rounded-pill fw-bold shadow-sm mt-auto" disabled>
                        <i class="bi bi-archive-fill me-2"></i> Úkol je archivován
                    </button>
                }
            }
            else
            {
                if (Model.TaskItem.Status == Models.Enums.TaskStatus.Completed)
                {
                    <button class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm mt-auto opacity-75" disabled>
                        <i class="bi bi-trophy-fill me-2"></i> Úkol je úspěšně dokončen
                    </button>
                }
                else if (Model.TaskItem.Status == Models.Enums.TaskStatus.Archived)
                {
                    <button class="btn btn-secondary w-100 py-3 rounded-pill fw-bold shadow-sm mt-auto" disabled>
                        <i class="bi bi-archive-fill me-2"></i> Úkol je archivován
                    </button>
                }
                else if (Model.TaskItem.Status == Models.Enums.TaskStatus.InProgress && Model.TaskItem.AssignedToId == Model.CurrentUserId)
                {
                    <form method="post" asp-page-handler="Finish" asp-route-id="@Model.TaskItem.Id" class="mt-auto">
                        <button type="submit" class="btn btn-success w-100 py-3 rounded-pill fw-bold shadow-sm">
                            <i class="bi bi-check2-all me-2"></i> Označit úkol jako splněný
                        </button>
                    </form>
                }
                else if (Model.TaskItem.Status == Models.Enums.TaskStatus.Open)
                {
                    if (Model.IsExpired)
                    {
                        <button class="btn btn-danger w-100 py-3 rounded-pill fw-bold shadow-sm mt-auto" disabled>
                            <i class="bi bi-calendar-x-fill me-2"></i> Termín úkolu vypršel
                        </button>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Accept" asp-route-id="@Model.TaskItem.Id" class="mt-auto">
                            <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm">
                                <i class="bi bi-check2-circle me-2"></i> Přijmout úkol
                            </button>
                        </form>
                    }
                }
                else if (Model.TaskItem.Status == Models.Enums.TaskStatus.WaitingForReview && Model.TaskItem.AssignedToId == Model.CurrentUserId)
                {
                    <button class="btn btn-info w-100 py-3 rounded-pill fw-bold shadow-sm mt-auto text-dark" disabled>
                        <i class="bi bi-clock-history me-2"></i> Čeká na schválení autorem
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary w-100 py-3 rounded-pill fw-bold shadow-sm mt-auto" disabled>
                        <i class="bi bi-person-check-fill me-2"></i> Úkol už řeší někdo jiný
                    </button>
                }
            }
            
            @if (!Model.IsMyTask && User.Identity is { IsAuthenticated: true })
            {
                <div class="text-center mt-3">
                    <button class="btn btn-link text-muted small text-decoration-none" 
                            onclick="openReportModal(@Model.TaskItem.Id)">
                        <i class="bi bi-flag-fill me-1"></i> Nahlásit problém s tímto úkolem
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<partial name="_ReportModalPartial" />

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/Tasks/detail.js" asp-append-version="true"></script>
    <script src="~/js/Tasks/report_modal.js" asp-append-version="true"></script>
}