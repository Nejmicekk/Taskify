@page
@model Taskify.Pages.Notifications.IndexModel
@using Taskify.Models.Enums
@{
    ViewData["Title"] = "Moje oznámení";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0 fw-bold">Moje oznámení</h4>
                        <div class="dropdown">
                            <button class="btn btn-light btn-sm rounded-circle no-anim" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 32px; height: 32px; padding: 0;">
                                <i class="bi bi-three-dots"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                @if (Model.Notifications.Any(n => !n.IsRead))
                                {
                                    <li>
                                        <button class="dropdown-item py-2 d-flex align-items-center gap-2" onclick="markAllAsRead(event)">
                                            <i class="bi bi-check-all fs-5 text-primary"></i> Označit vše jako přečtené
                                        </button>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li>
                                    <a class="dropdown-item py-2 d-flex align-items-center gap-2" asp-area="Identity" asp-page="/Account/Manage/Notifications">
                                        <i class="bi bi-gear fs-5 text-secondary"></i> Nastavení oznámení
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <a asp-page="./Index" asp-route-filter="all" 
                           class="btn btn-sm rounded-pill px-4 fw-bold no-anim d-inline-flex align-items-center justify-content-center @(Model.Filter == "all" ? "btn-primary" : "btn-light text-secondary")">
                            Všechna
                        </a>
                        <a asp-page="./Index" asp-route-filter="unread" 
                           class="btn btn-sm rounded-pill px-4 fw-bold no-anim d-inline-flex align-items-center justify-content-center @(Model.Filter == "unread" ? "btn-primary" : "btn-light text-secondary")">
                            Nepřečtená
                        </a>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (Model.Notifications.Any())
                    {
                        <div class="list-group list-group-flush border-0">
                            <partial name="_NotificationItemsPartial" model="Model.Notifications" />
                        </div>
                    }
                    else
                    {
                        <div class="p-5 text-center">
                            <div class="bg-light d-inline-flex p-4 rounded-circle mb-3">
                                <i class="bi bi-bell-slash fs-1 text-muted"></i>
                            </div>
                            <h5>Zatím žádná oznámení</h5>
                            <p class="text-muted">Jakmile se něco stane, dáme vám vědět.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
