@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Obnovení hesla";
    ViewData["HideNavbar"] = true;
    ViewData["HideFooter"] = true;
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">

    <div class="card border-0 shadow-lg" style="width: 100%; max-width: 450px; border-radius: 1rem;">
        <div class="card-body p-5">

            <div class="text-center mb-4">
                <div class="mb-3 text-primary">
                    <h2 class="d-inline-block align-middle fw-bold ms-2 text-primary">Taskify</h2>
                </div>
                <h3 class="fw-bold">Nové heslo</h3>
                <p class="text-muted">Nastavte si nové silné heslo pro svůj účet.</p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                
                <input asp-for="Input.Code" type="hidden" />
                
                <input asp-for="Input.Email" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label fw-semibold">Nové heslo</label>
                    <input asp-for="Input.Password" class="form-control form-control-lg bg-light fs-6" autocomplete="new-password" aria-required="true" placeholder="Zadejte nové heslo"/>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">Potvrzení hesla</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control form-control-lg bg-light fs-6" autocomplete="new-password" aria-required="true" placeholder="Zadejte heslo znovu"/>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 fs-6">Uložit nové heslo</button>
            </form>
            
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}