@page
@model LoginWith2faModel
@{
    ViewData["Title"] = "Dvoufázové ověření";
    ViewData["HideNavbar"] = true;
    ViewData["HideFooter"] = true;
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">

    <div class="card border-0 shadow-lg" style="width: 100%; max-width: 450px; border-radius: 1rem;">
        <div class="card-body p-5">

            <div class="text-center mb-4">
                <div class="mb-3 text-primary">
                    <h2 class="d-inline-block align-middle fw-bold ms-2 text-primary">Taskify</h2>
                </div>
                <h3 class="fw-bold">@ViewData["Title"]</h3>
                <p class="text-muted">Vaše přihlášení je chráněno autentizační aplikací. Zadejte kód.</p>
            </div>

            <section>
                <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
                    <input asp-for="RememberMe" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="mb-3 text-start">
                        <label asp-for="Input.TwoFactorCode" class="form-label fw-bold text-dark">Ověřovací kód</label>
                        <input asp-for="Input.TwoFactorCode" class="form-control form-control-lg bg-light fs-6" autocomplete="off" placeholder="000 000" />
                        <span asp-validation-for="Input.TwoFactorCode" class="text-danger small ms-1"></span>
                    </div>

                    <div class="d-flex align-items-center mb-4 ps-1">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="Input.RememberMachine" />
                            <label class="form-check-label text-secondary" asp-for="Input.RememberMachine">
                                Zapamatovat tento prohlížeč
                            </label>
                        </div>
                    </div>

                    <div class="mb-4">
                        <button type="submit" class="btn btn-primary btn-lg w-100 fs-6 fw-bold">Ověřit a přihlásit</button>
                    </div>

                    <div class="text-center border-top pt-4">
                        <p class="small text-muted mb-2">Nemáte přístup k zařízení?</p>
                        <a id="recovery-code-login" asp-page="./LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold">Použít obnovovací kód</a>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
