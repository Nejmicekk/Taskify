@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Zapomenuté heslo";
    ViewData["HideNavbar"] = true;
    ViewData["HideFooter"] = true;
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">

    <div class="card border-0 shadow-lg" style="width: 100%; max-width: 450px; border-radius: 1rem;">
        <div class="card-body p-5">

            <div class="text-center mb-4">
                <div class="mb-3 text-primary">
                    <h2 class="d-inline-block align-middle fw-bold ms-2 text-primary">Taskify</h2>
                </div>
                <h3 class="fw-bold">Zapomenuté heslo?</h3>
                <p class="text-muted">Nebojte, to se stává. Zadejte svůj e-mail a my vám pošleme instrukce k obnovení.</p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="mb-4 text-start">
                    <label asp-for="Input.Email" class="form-label fw-bold text-dark">E-mailová adresa</label>
                    <input asp-for="Input.Email" class="form-control bg-light border-1 py-2" autocomplete="username" aria-required="true" placeholder="jan@novak.cz" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary btn-lg w-100 fs-6">Odeslat odkaz</button>
                </div>

                <div class="text-center mt-3">
                    <a asp-page="./Login" class="text-decoration-none fw-bold">
                        <i class="bi bi-arrow-left me-1"></i>Zpět na přihlášení
                    </a>
                </div>
            </form>
            
        </div>
    </div>
</div>