@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Heslo změněno";
    ViewData["HideNavbar"] = true;
    ViewData["HideFooter"] = true;
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">

    <div class="card border-0 shadow-lg" style="width: 100%; max-width: 500px; border-radius: 1rem;">
        <div class="card-body p-5 text-center">

            <div class="mb-4">
                <i class="bi bi-shield-check text-success" style="font-size: 4rem;"></i>
            </div>

            <h2 class="fw-bold mb-3">Hotovo!</h2>
            
            <p class="text-muted mb-4">
                Vaše heslo bylo úspěšně obnoveno. Nyní se můžete přihlásit pomocí nového hesla.
            </p>

            <a asp-page="./Login" class="btn btn-primary btn-lg w-100 fs-6">
                <i class="bi bi-box-arrow-in-right me-2"></i>Přihlásit se
            </a>

        </div>
    </div>
</div>