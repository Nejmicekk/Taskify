@page
@model LoginModel

@{
    ViewData["Title"] = "Přihlášení";
    ViewData["HideNavbar"] = true;
    ViewData["HideFooter"] = true;
}

<div class="container d-flex justify-content-center align-items-center min-vh-100 py-5">
    
    <div class="card border-0 shadow-lg" style="width: 100%; max-width: 450px; border-radius: 1rem;">
        <div class="card-body p-5">
            
            <div class="text-center mb-4">
                <div class="mb-3 text-primary">
                    <h2 class="d-inline-block align-middle fw-bold ms-2 text-primary">Taskify</h2>
                </div>
                <h3 class="fw-bold">Přihlášení</h3>
                <p class="text-muted">Vítejte zpět! Zadejte přihlašovací údaje.</p>
            </div>

            <section>
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="mb-3 text-start">
                        <label asp-for="Input.Email" class="form-label fw-bold text-dark">Email / Uživatelské jméno </label>
                        <input asp-for="Input.Email" class="form-control bg-light border-1 py-2" type="text" autocomplete="username" aria-required="true" placeholder="Email nebo uživatelské jméno" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-semibold">Heslo</label>
                        <input asp-for="Input.Password" class="form-control form-control-lg bg-light fs-6" autocomplete="current-password" aria-required="true" placeholder="Heslo" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label text-secondary" asp-for="Input.RememberMe">
                                Zapamatovat si mě
                            </label>
                        </div>
                        <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none small fw-bold">Zapomenuté heslo</a>
                    </div>

                    <div class="mb-3">
                        <button id="login-submit" type="submit" class="btn btn-primary btn-lg w-100 fs-6">Přihlásit se</button>
                    </div>

