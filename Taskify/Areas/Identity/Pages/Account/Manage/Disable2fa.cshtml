@page
@model Disable2faModel
@{
    ViewData["Title"] = "Vypnout 2FA";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-4 p-md-5 text-center">
        <div class="icon-box bg-danger bg-opacity-10 text-danger d-inline-flex p-3 rounded-circle mb-3">
            <i class="bi bi-shield-x fs-1"></i>
        </div>
        <h4 class="fw-bold mb-3">@ViewData["Title"]</h4>
        
        <div class="alert alert-warning rounded-4 mb-4 text-start">
            <p class="mb-0">
                <strong>Tato akce vypne dvoufázové ověření.</strong>
                Vypnutím 2FA se nezmění klíče v autentizačních aplikacích. Pokud chcete změnit klíče, 
                musíte <a asp-page="./ResetAuthenticator" class="fw-bold">resetovat své autentifikační kódy</a>.
            </p>
        </div>

        <form method="post">
            <div class="d-flex gap-2 justify-content-center">
                <button class="btn btn-danger rounded-pill px-4 fw-bold" type="submit">Vypnout 2FA</button>
                <a asp-page="./Security" class="btn btn-light rounded-pill px-4">Zrušit</a>
            </div>
        </form>
    </div>
</div>
