@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Změna hesla";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<nav aria-label="breadcrumb" class="mt-4 mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/u/@User.Identity?.Name" class="text-decoration-none text-muted">Profil</a></li>
        <li class="breadcrumb-item"><a asp-page="./Index" class="text-decoration-none text-muted">Nastavení účtu</a></li>
        <li class="breadcrumb-item active fw-bold text-dark">Změna hesla</li>
    </ol>
</nav>

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-page="./Index" class="btn btn-outline-secondary rounded-pill shadow-sm btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h2 class="fw-bold mb-0">@ViewData["Title"]</h2>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5">
                <h5 class="fw-bold mb-4">Změna přístupových údajů</h5>
                <form id="change-password-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.OldPassword" class="form-control rounded-3" autocomplete="current-password" aria-required="true" />
                        <label asp-for="Input.OldPassword">Současné heslo</label>
                        <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.NewPassword" class="form-control rounded-3" autocomplete="new-password" aria-required="true" />
                        <label asp-for="Input.NewPassword">Nové heslo</label>
                        <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.ConfirmPassword" class="form-control rounded-3" autocomplete="new-password" aria-required="true" />
                        <label asp-for="Input.ConfirmPassword">Potvrzení nového hesla</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-sm">
                        <i class="bi bi-key me-2"></i>Aktualizovat heslo
                    </button>
                </form>
            </div>
        </div>
        
        <div class="mt-4 p-3 bg-light rounded-4 border">
            <p class="small text-muted mb-0">
                <i class="bi bi-info-circle me-2"></i>
                Doporučujeme používat silné heslo o délce alespoň 8 znaků kombinující velká a malá písmena, číslice a symboly.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
