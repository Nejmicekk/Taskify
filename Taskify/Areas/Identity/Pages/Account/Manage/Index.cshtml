@page
@model IndexModel
@{
    ViewData["Title"] = "Nastavení účtu";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" />
<link rel="stylesheet" href="~/css/Profile/profile.css" asp-append-version="true" />

<nav aria-label="breadcrumb" class="mt-4 mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/u/@Model.Username" class="text-decoration-none text-muted">Profil</a></li>
        <li class="breadcrumb-item active fw-bold text-dark">Nastavení účtu</li>
    </ol>
</nav>

<h2 class="fw-bold mb-4">@ViewData["Title"]</h2>

@if (!Model.AreNotificationsEnabled)
{
    <div class="alert alert-info border-0 shadow-sm rounded-4 mb-4 d-flex align-items-center p-4">
        <div class="icon-box bg-info bg-opacity-10 text-info me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; flex-shrink: 0;">
            <i class="bi bi-bell-slash fs-4"></i>
        </div>
        <div class="flex-grow-1">
            <h6 class="fw-bold mb-1">E-mailová oznámení jsou vypnutá</h6>
            <p class="small mb-0 text-muted">Pro plnohodnotný zážitek z aplikace Taskify doporučujeme zapnout oznámení. Budete tak vědět o nových úkolech a zprávách.</p>
        </div>
        <div class="ms-3">
            <a asp-page="./Notifications" class="btn btn-info btn-sm rounded-pill px-3 fw-bold text-white">Zapnout</a>
        </div>
    </div>
}

<div class="row justify-content-center">
    <div class="col-md-11 col-lg-9">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Osobní údaje</h5>
                    <button type="button" id="edit-btn" class="btn btn-primary rounded-pill px-4 shadow-sm" onclick="enableEdit()">
                        <i class="bi bi-pencil me-2"></i>Upravit
                    </button>
                </div>

                <form id="profile-form" method="post" enctype="multipart/form-data">
                    <input type="file" asp-for="Input.ProfilePicture" id="upload-photo" class="d-none" accept="image/*" onchange="previewImage(this)">

                    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                        <div class="profile-pic-wrapper shadow-sm border me-3" onclick="document.getElementById('upload-photo').click()" title="Změnit profilovou fotku">
                            @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl)) 
                            {
                                <img id="img-preview" src="@Model.ProfilePictureUrl" alt="Profilovka" class="profile-pic-img">
                            }
                            else
                            {
                                <div id="initials-placeholder" class="bg-primary text-white d-flex align-items-center justify-content-center w-100 h-100" style="font-size: 24px;">
                                    @(Model.Username?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                                <img id="img-preview" src="#" alt="Náhled" class="profile-pic-img d-none">
                            }
                            <div class="profile-pic-overlay"><i class="bi bi-camera-fill"></i></div>
                        </div>
                        <div>
                            <div class="fw-bold">Profilová fotografie</div>
                            <small class="text-muted">Klikněte na fotku pro změnu</small>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Name" class="form-control" disabled id="input-name" placeholder="Zadejte zobrazované jméno"/>
                                <label asp-for="Input.Name">Zobrazované jméno</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Username" class="form-control" disabled id="input-username"/>
                                <label asp-for="Input.Username">Uživatelské jméno</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Email" class="form-control" disabled id="input-email"/>
                                <label asp-for="Input.Email">E-mailová adresa</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <textarea asp-for="Input.Bio" class="form-control" style="height: 120px" disabled id="input-bio"></textarea>
                        <label asp-for="Input.Bio">O mně (Bio)</label>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.PhoneNumber" class="form-control" disabled id="input-phone"/>
                        <label asp-for="Input.PhoneNumber">Telefonní číslo</label>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div id="save-actions" class="d-none border-top pt-4">
                        <div class="d-flex gap-2">
                            <button id="save-btn" type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm">Uložit změny</button>
                            <button type="button" class="btn btn-light rounded-pill px-4 text-muted" onclick="location.reload()">Zrušit</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="row mt-4 g-4 settings-cards">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 rounded-4 h-100 settings-card">
                    <div class="card-body p-4 d-flex flex-column text-center">
                        <div class="icon-box mx-auto mb-3">
                            <i class="bi bi-shield-lock fs-2"></i>
                        </div>
                        <h6 class="fw-bold mb-2">Zabezpečení a heslo</h6>
                        <p class="text-muted small mb-4">Změňte si heslo nebo nastavte 2FA.</p>
                        <div class="mt-auto">
                            <a asp-page="./Security" class="btn btn-outline-primary rounded-pill fw-bold w-100 py-2 no-anim">Přejít do nastavení</a>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card shadow-sm border-0 rounded-4 h-100 settings-card">
                    <div class="card-body p-4 d-flex flex-column text-center">
                        <div class="icon-box mx-auto mb-3">
                            <i class="bi bi-bell fs-2"></i>
                        </div>
                        <h6 class="fw-bold mb-2">Oznámení</h6>
                        <p class="text-muted small mb-4">Nastavte si, co vám má chodit na e-mail.</p>
                        <div class="mt-auto">
                            <a asp-page="./Notifications" class="btn btn-outline-primary rounded-pill fw-bold w-100 py-2 no-anim">Nastavit oznámení</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-0 rounded-4 h-100 settings-card">
                    <div class="card-body p-4 d-flex flex-column text-center">
                        <div class="icon-box mx-auto mb-3">
                            <i class="bi bi-person-gear fs-2"></i>
                        </div>
                        <h6 class="fw-bold mb-2">Osobní data a účet</h6>
                        <p class="text-muted small mb-4">Správa dat a pozastavení účtu.</p>
                        <div class="mt-auto">
                            <a asp-page="./PersonalData" class="btn btn-outline-primary rounded-pill fw-bold w-100 py-2 no-anim">Spravovat účet</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

<style>
    .settings-card { 
        transition: transform 0.2s ease, box-shadow 0.2s ease; 
        border: 1px solid rgba(0,0,0,0.05) !important;
    }
    .settings-card:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 10px 25px rgba(13, 110, 253, 0.1) !important; 
    }
    
    .settings-card .icon-box {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 16px;
        background-color: rgba(13, 110, 253, 0.08);
        color: #0d6efd;
    }

    .settings-card .btn-outline-primary {
        border-width: 2px;
        font-size: 0.9rem;
    }
    
    .settings-card .btn-outline-primary:hover {
        background-color: #0d6efd;
        color: white;
    }
</style>
    </div>
</div>


<div class="modal fade" id="errorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-danger rounded-4">
            <div class="modal-header bg-danger text-white border-0 py-3 rounded-top-4">
                <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i> Nastala chyba</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Zavřít"></button>
            </div>
            <div class="modal-body p-4">
                <div asp-validation-summary="All" class="text-danger fw-bold"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="cropModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Upravit fotku</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zavřít"></button>
            </div>
            <div class="modal-body p-0">
                <div class="img-container" style="height: 400px; background-color: #f8f9fa;">
                    <img id="image-to-crop" src="" style="display: block; max-width: 100%;">
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Zrušit</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" id="crop-btn">Uložit</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
    <script src="~/js/Profile/profile.js" asp-append-version="true"></script>
}