@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Odesláno";
    ViewData["HideNavbar"] = true;
    ViewData["HideFooter"] = true;
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">

    <div class="card border-0 shadow-lg" style="width: 100%; max-width: 500px; border-radius: 1rem;">
        <div class="card-body p-5 text-center">

            <div class="mb-4">
                <i class="bi bi-envelope-check-fill text-success" style="font-size: 4rem;"></i>
            </div>

            <h2 class="fw-bold mb-3">Zkontrolujte si e-mail</h2>
            
            <p class="text-muted">
                Pokud existuje účet s tímto e-mailem, tak jsme Vám odeslali instrukce k obnovení hesla.
            </p>
            
            <div class="alert alert-light border mt-4 text-start d-inline-block bg-light">
                <small class="text-muted">
                    <i class="bi bi-info-circle me-1"></i>
                    Nezapomeňte zkontrolovat i složku <strong>Spam</strong> nebo <strong>Hromadné</strong>.
                </small>
            </div>

            <div class="mt-4">
                <a asp-page="./Login" class="btn btn-primary btn-lg w-100 fs-6">Zpět na přihlášení</a>
            </div>

        </div>
    </div>
</div>