@page
@model ConfirmEmailChangeModel
@{
    ViewData["Title"] = "Změna e-mailu";
}

<div class="container mt-5 text-center">
    <div class="card shadow-sm p-5 mx-auto" style="max-width: 500px;">
        <i class="bi bi-check-circle-fill text-success mb-3" style="font-size: 3rem;"></i>
        
        <h2 class="mb-3">Hotovo!</h2>
        
        <p class="text-muted">
            Vaše e-mailová adresa byla úspěšně změněna.<br>
            Z bezpečnostních důvodů jsme vás odhlásili.
        </p>
        
        <a asp-page="/Account/Login" class="btn btn-primary w-100 mt-3">
            <i class="bi bi-box-arrow-in-right me-2"></i>Přihlásit se znovu
        </a>
    </div>
</div>